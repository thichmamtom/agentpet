---
import "../styles/global.css";
import Icon from "../components/Icon.astro";
import SurprisePet from "../components/SurprisePet.astro";
import { DICT } from "../i18n/dict";
interface Props { title?: string; description?: string; active?: string; }
const { title = "AgentPet", description = "Adopt, build, and share pixel companions for your AI coding agents.", active = "" } = Astro.props;
const nav = [
  { href: "/gallery", label: "Gallery", key: "gallery" },
  { href: "/collections", label: "Collections", key: "collections" },
  { href: "/leaderboard", label: "Leaderboard", key: "leaderboard" },
  { href: "/requests", label: "Requests", key: "requests" },
  { href: "/make", label: "Make", key: "make" },
  { href: "/integrations", label: "Integrations", key: "integrations" },
  { href: "/creators", label: "Creators", key: "creators" },
  { href: "/docs", label: "Docs", key: "docs" },
];
// Keep the inline bar short (fits long Vietnamese labels); the rest go under "More".
const PRIMARY = ["gallery", "collections", "leaderboard", "make", "docs"];
const primaryNav = nav.filter((n) => PRIMARY.includes(n.key));
const moreNav = nav
  .filter((n) => !PRIMARY.includes(n.key))
  .concat([{ href: "/contributors", label: "Contributors", key: "contributors" }]);
const DISCORD = "https://discord.gg/kzFJKsZav";
const GITHUB = "https://github.com/ntd4996/agentpet";

// Ambient clouds drifting across the whole page (denser = dreamier sky).
const cloudSrc = ["cloud1", "cloud2", "cloud3", "cloud4", "cloud5", "cloud6"];
const widths = [40, 48, 56, 64, 72, 80];
// Clouds drift gently across the full width. Phases are spread evenly so that at
// any moment the two gutters still have clouds even when the middle ones pass
// behind the card list. Moderate count so it never feels crowded.
const N_CLOUDS = 20;
const clouds = Array.from({ length: N_CLOUDS }, (_, i) => ({
  src: cloudSrc[i % cloudSrc.length],
  top: Math.round(((i * 43 + (i % 3) * 9) % 100) * 10) / 10,
  w: widths[(i * 5) % widths.length],
  op: [0.4, 0.46, 0.52, 0.55][i % 4],
  dur: 88 + (i % 5) * 7,
  delay: -Math.round((i / N_CLOUDS) * 96 * 10) / 10,
}));
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/logo.png" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://agentpet.thenightwatcher.online/og.png?v=2" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://agentpet.thenightwatcher.online/og.png?v=2" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@500;600;700&family=Baloo+2:wght@500;600;700&family=Pixelify+Sans:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="min-h-screen">
  <!-- ambient sky: spans the whole page (scrolls with it). Clouds drift behind
       everything; small islands bob in the gutters at varied depths. -->
  <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden" aria-hidden="true">
    {clouds.map((c) => (
      <img src={`/island/${c.src}.png`} alt="" class="cloud pixel-art" style={`top:${c.top}%; width:${c.w * 4}px; opacity:${c.op}; animation: drift ${c.dur}s linear infinite ${c.delay}s`} />
    ))}

    <img src="/island/isl-cherry.png" alt="" class="bob pixel-art absolute hidden w-24 opacity-70 lg:block" style="left:1.5%; top:22%; animation-delay:-1.2s" />
    <img src="/island/isl-chest.png" alt="" class="bob-3 pixel-art absolute hidden w-16 opacity-60 lg:block" style="right:2%; top:52%; animation-delay:-1.6s" />
    <img src="/island/isl-grove.png" alt="" class="bob-slow pixel-art absolute hidden w-20 opacity-55 lg:block" style="left:2%; top:84%; animation-delay:-4s" />

    <!-- flying-friend mascots scattered down the page, drifting like the islands -->
    <img src="/art/isl-balloon.webp" alt="" class="bob-2 absolute hidden w-24 opacity-80 lg:block xl:w-28" style="right:2.5%; top:32%; filter: drop-shadow(0 12px 12px rgba(30,58,130,.18)); animation-delay:-0.7s" />
    <img src="/art/isl-cottage.webp" alt="" class="bob absolute hidden w-24 opacity-80 lg:block xl:w-28" style="left:2%; top:46%; filter: drop-shadow(0 12px 12px rgba(30,58,130,.18)); animation-delay:-2.3s" />
    <img src="/art/isl-skylands.webp" alt="" class="bob-3 absolute hidden w-28 opacity-80 lg:block xl:w-32" style="right:1.5%; top:70%; filter: drop-shadow(0 12px 12px rgba(30,58,130,.18)); animation-delay:-1.5s" />
  </div>

  <header class="sticky top-3 z-30 px-4">
    <nav class="nav-pill mx-auto flex max-w-7xl items-center gap-2 rounded-full px-3 py-2">
      <a href="/" class="flex shrink-0 items-center gap-2 pl-1 pr-1 font-display text-lg font-bold text-ink">
        <img src="/logo.png" alt="" class="h-9 w-9 rounded-xl" />
        <span data-no-i18n>Agent<span class="text-brand-600">Pet</span></span>
      </a>
      <!-- inline nav: only when there's room (xl+) -->
      <div class="ml-1 hidden items-center gap-0.5 xl:flex">
        {primaryNav.map((n) => (
          <a href={n.href} class={`nav-link ${active === n.key ? "active" : ""}`} data-i18n={n.label}>{n.label}</a>
        ))}
        <div class="group relative">
          <button type="button" class={`nav-link inline-flex items-center gap-1 ${moreNav.some((n) => n.key === active) ? "active" : ""}`} aria-haspopup="true">
            <span data-i18n="More">More</span>
            <Icon name="chevron" class="h-3.5 w-3.5 opacity-60" />
          </button>
          <div class="invisible absolute left-0 top-full pt-2 opacity-0 transition group-hover:visible group-hover:opacity-100">
            <div class="w-44 rounded-2xl border border-line bg-white p-1.5 shadow-card">
              {moreNav.map((n) => (
                <a href={n.href} class={`block rounded-xl px-3 py-2 text-sm font-semibold transition hover:bg-brand-50 hover:text-brand-700 ${active === n.key ? "bg-brand-50 text-brand-700" : "text-muted"}`} data-i18n={n.label}>{n.label}</a>
              ))}
            </div>
          </div>
        </div>
      </div>
      <div class="ml-auto flex shrink-0 items-center gap-1.5">
        <div id="lang-switch" class="relative hidden sm:block">
          <button id="lang-toggle" type="button" aria-haspopup="true" aria-expanded="false" aria-label="Language" class="flex items-center gap-1 rounded-full border border-line bg-white/70 py-2 pl-2.5 pr-2 text-sm font-semibold text-muted transition hover:border-brand-300 hover:text-brand-700">
            <Icon name="globe" class="h-4 w-4" />
            <span data-lang-current class="min-w-[1.4rem] text-center">EN</span>
            <Icon name="chevron" class="h-3.5 w-3.5 opacity-60" />
          </button>
          <div id="lang-menu" class="absolute right-0 z-50 mt-2 hidden w-40 rounded-2xl border border-line bg-white p-1.5 shadow-card">
            <button type="button" data-lang-btn="en" class="lang-item"><span>English</span><Icon name="check" class="lang-check h-4 w-4 text-brand-600" /></button>
            <button type="button" data-lang-btn="vi" class="lang-item"><span>Tiếng Việt</span><Icon name="check" class="lang-check h-4 w-4 text-brand-600" /></button>
            <button type="button" data-lang-btn="zh" class="lang-item"><span>中文</span><Icon name="check" class="lang-check h-4 w-4 text-brand-600" /></button>
            <button type="button" data-lang-btn="zh-TW" class="lang-item"><span>正體中文</span><Icon name="check" class="lang-check h-4 w-4 text-brand-600" /></button>
          </div>
        </div>
        <a href={DISCORD} target="_blank" rel="noopener" aria-label="Discord" class="hidden rounded-full p-2.5 text-muted transition hover:bg-brand-50 hover:text-brand-700 sm:inline-flex">
          <Icon name="discord" />
        </a>
        <a href={GITHUB} target="_blank" rel="noopener" aria-label="GitHub" class="hidden rounded-full p-2.5 text-muted transition hover:bg-brand-50 hover:text-brand-700 sm:inline-flex">
          <Icon name="github" class="h-5 w-5" />
        </a>
        <div id="ap-auth" class="flex items-center">
          <a href="/api/auth/login?returnTo=/" class="btn-ghost !px-3 !py-2"><Icon name="users" class="h-4 w-4" /> <span class="hidden sm:inline" data-i18n="Sign in">Sign in</span></a>
        </div>
        <a href="/install" class="btn-primary !px-4 !py-2">
          <Icon name="download" class="h-4 w-4" /> <span class="hidden sm:inline" data-i18n="Get the app">Get the app</span>
        </a>
        <!-- menu toggle: below xl -->
        <button id="navToggle" type="button" aria-label="Menu" aria-expanded="false" class="grid h-10 w-10 shrink-0 place-items-center rounded-full text-muted transition hover:bg-brand-50 hover:text-brand-700 xl:hidden">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="h-5 w-5"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
        </button>
      </div>
    </nav>
    <!-- collapsed nav menu -->
    <div id="navMenu" class="mx-auto mt-2 hidden max-w-7xl px-1 xl:!hidden">
      <div class="rounded-2xl border border-line bg-white p-2 shadow-card">
        {nav.map((n) => (
          <a href={n.href} class={`block rounded-xl px-3 py-2 text-sm font-semibold transition hover:bg-brand-50 hover:text-brand-700 ${active === n.key ? "bg-brand-50 text-brand-700" : "text-muted"}`} data-i18n={n.label}>{n.label}</a>
        ))}
        <div class="mt-2 flex items-center gap-1 rounded-xl border border-line bg-brand-50/40 p-1" role="group" aria-label="Language">
          <button type="button" data-lang-btn="en" class="lang-seg flex-1">EN</button>
          <button type="button" data-lang-btn="vi" class="lang-seg flex-1">Tiếng Việt</button>
          <button type="button" data-lang-btn="zh" class="lang-seg flex-1">中文</button>
          <button type="button" data-lang-btn="zh-TW" class="lang-seg flex-1">正體中文</button>
        </div>
      </div>
    </div>
  </header>
  <script>
    (() => {
      const t = document.getElementById("navToggle");
      const m = document.getElementById("navMenu");
      if (!t || !m) return;
      t.addEventListener("click", () => {
        const hidden = m.classList.toggle("hidden");
        t.setAttribute("aria-expanded", String(!hidden));
      });
      m.addEventListener("click", (e) => { if ((e.target as HTMLElement).closest("a")) m.classList.add("hidden"); });
    })();
  </script>

  <main class="relative">
    <slot />
  </main>

  <div class="px-4 pb-10 pt-24">
  <footer class="relative z-10 mx-auto max-w-6xl overflow-hidden rounded-[2rem] bg-white/70 backdrop-blur-md shadow-[0_24px_50px_-28px_rgba(24,33,63,0.32)]">
    <div class="grid gap-8 px-8 py-10 sm:grid-cols-2 md:grid-cols-4">
      <div class="sm:col-span-2 md:col-span-1">
        <div class="flex items-center gap-2 font-display text-lg font-bold text-ink">
          <img src="/logo.png" alt="" class="h-8 w-8 rounded-lg" /> AgentPet
        </div>
        <p class="mt-3 max-w-xs text-sm text-muted">A desktop pet that reacts while your AI coding agents work. Free and open source.</p>
        <div class="mt-4 flex gap-2">
          <a href={DISCORD} target="_blank" rel="noopener" aria-label="Discord" class="grid h-9 w-9 place-items-center rounded-full bg-brand-50 text-brand-600 transition hover:bg-brand-100"><Icon name="discord" class="h-4 w-4" /></a>
          <a href={GITHUB} target="_blank" rel="noopener" aria-label="GitHub" class="grid h-9 w-9 place-items-center rounded-full bg-brand-50 text-brand-600 transition hover:bg-brand-100"><Icon name="github" class="h-4 w-4" /></a>
        </div>
      </div>
      <div>
        <h4 class="font-display text-sm font-semibold text-ink" data-i18n="Explore">Explore</h4>
        <ul class="mt-3 space-y-2 text-sm text-muted">
          <li><a class="hover:text-brand-700" href="/gallery" data-i18n="Gallery">Gallery</a></li>
          <li><a class="hover:text-brand-700" href="/collections" data-i18n="Collections">Collections</a></li>
          <li><a class="hover:text-brand-700" href="/leaderboard" data-i18n="Leaderboard">Leaderboard</a></li>
          <li><a class="hover:text-brand-700" href="/make" data-i18n="Make a pet">Make a pet</a></li>
          <li><a class="hover:text-brand-700" href="/submit" data-i18n="Submit a pet">Submit a pet</a></li>
          <li><a class="hover:text-brand-700" href="/requests" data-i18n="Requests">Requests</a></li>
          <li><a class="hover:text-brand-700" href="/integrations" data-i18n="Integrations">Integrations</a></li>
          <li><a class="hover:text-brand-700" href="/creators" data-i18n="Creators">Creators</a></li>
          <li><a class="hover:text-brand-700" href="/contributors" data-i18n="Contributors">Contributors</a></li>
          <li><a class="hover:text-brand-700" href="/docs" data-i18n="Docs">Docs</a></li>
        </ul>
      </div>
      <div>
        <h4 class="font-display text-sm font-semibold text-ink" data-i18n="Community">Community</h4>
        <ul class="mt-3 space-y-2 text-sm text-muted">
          <li><a class="hover:text-brand-700" href={DISCORD} target="_blank" rel="noopener">Discord</a></li>
          <li><a class="hover:text-brand-700" href={GITHUB} target="_blank" rel="noopener">GitHub</a></li>
          <li><a class="hover:text-brand-700" href="/install" data-i18n="Install guide">Install guide</a></li>
          <li><a class="hover:text-brand-700" href="/legal" data-i18n="Legal & takedown">Legal &amp; takedown</a></li>
        </ul>
      </div>
      <div>
        <h4 class="font-display text-sm font-semibold text-ink" data-i18n="Get started">Get started</h4>
        <p class="mt-3 text-sm text-muted" data-i18n="Download AgentPet and pick a companion.">Download AgentPet and pick a companion.</p>
        <a href="/install" class="btn-primary mt-4 !px-4 !py-2"><Icon name="download" class="h-4 w-4" /> <span data-i18n="Get the app">Get the app</span></a>
      </div>
    </div>
    <div class="flex flex-wrap items-center justify-between gap-x-4 gap-y-2 border-t border-line/70 px-8 py-5">
      <p class="text-xs text-faint">© 2026 AgentPet · Open source (MIT) · Made for terminal dwellers.</p>
      <a href="/legal" class="text-xs font-medium text-faint transition hover:text-brand-700">Legal &amp; takedown</a>
    </div>
  </footer>
  </div>

  <!-- Scroll to top: appears after scrolling down a bit. -->
  <button id="toTop" type="button" aria-label="Scroll to top" data-i18n-title="Scroll to top" title="Scroll to top"
    class="fixed bottom-5 right-5 z-40 grid h-11 w-11 place-items-center rounded-full border border-line bg-white text-brand-600 shadow-card transition hover:bg-brand-50 hover:text-brand-700">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><path d="M12 19V5m0 0l-6 6m6-6l6 6"/></svg>
  </button>
  <script is:inline>
    (function () {
      var btn = document.getElementById("toTop");
      if (!btn) return;
      function onScroll() { btn.classList.toggle("show", window.scrollY > 400); }
      btn.addEventListener("click", function () { window.scrollTo({ top: 0, behavior: "smooth" }); });
      window.addEventListener("scroll", onScroll, { passive: true });
      onScroll();
    })();
  </script>

  <!-- Full-site client localization: a language switcher + persisted choice.
       Auto-translates text nodes, [data-i18n] elements, and data-i18n-<attr>
       attributes whose English text matches a key in DICT. Works on every page
       (static + SSR). Remembers the choice in localStorage for next visit. -->
  <script is:inline define:vars={{ DICT }}>
    (function () {
      var LANGS = ["en", "vi", "zh", "zh-TW"];
      var HTML_LANG = { en: "en", vi: "vi", zh: "zh-Hans", "zh-TW": "zh-Hant" };
      var STORE_KEY = "ap_lang";
      var ATTRS = ["placeholder", "title", "aria-label", "alt", "content", "value"];
      var SKIP = { SCRIPT: 1, STYLE: 1, NOSCRIPT: 1, CODE: 1, PRE: 1, TEXTAREA: 1, INPUT: 1, SELECT: 1, OPTION: 1, SVG: 1, svg: 1 };

      function detect() {
        try { var s = localStorage.getItem(STORE_KEY); if (s && LANGS.indexOf(s) >= 0) return s; } catch (e) {}
        var l = (navigator.language || "").toLowerCase();
        if (l.indexOf("vi") === 0) return "vi";
        if (l === "zh-tw" || l === "zh-hk" || l === "zh-mo" || l.indexOf("zh-hant") === 0) return "zh-TW";
        if (l.indexOf("zh") === 0) return "zh";
        return "en";
      }
      function tr(lang, en) {
        if (lang === "en") return en;
        var d = DICT[lang];
        return (d && d[en] != null) ? d[en] : en;
      }

      // Build a set of all known English keys for the auto text-node pass.
      var KNOWN = {};
      for (var L in DICT) for (var k in DICT[L]) KNOWN[k] = 1;

      // Original-English captured ONCE per node (while the DOM is still
      // English), so switching back to EN restores it correctly.
      var textList = [];            // text nodes we manage
      var elList = [];              // [data-i18n] elements (en read from attribute)
      var attrList = [];            // { el, attr }
      var textOrig = new WeakMap();  // textNode -> { en, pre, post }
      var attrOrig = new WeakMap();  // el -> { attr: en }

      function inSkip(node) {
        for (var p = node.parentNode; p && p.nodeType === 1; p = p.parentNode) {
          if (SKIP[p.tagName]) return true;
          if (p.hasAttribute && p.hasAttribute("data-no-i18n")) return true;
        }
        return false;
      }
      function inExplicit(node) {
        for (var p = node.parentNode; p && p.nodeType === 1; p = p.parentNode)
          if (p.hasAttribute && p.hasAttribute("data-i18n")) return true;
        return false;
      }
      function trackAttr(el, attr, en) {
        var o = attrOrig.get(el) || {};
        if (o[attr] != null) return;
        o[attr] = en; attrOrig.set(el, o); attrList.push({ el: el, attr: attr });
      }
      // Idempotent: only captures nodes not seen before. Safe to call again
      // after dynamic content (e.g. the auth menu) is injected.
      function collect() {
        document.querySelectorAll("[data-i18n]").forEach(function (el) {
          if (el.__i18n) return; el.__i18n = 1; elList.push(el);
        });
        ATTRS.forEach(function (attr) {
          document.querySelectorAll("[data-i18n-" + attr + "]").forEach(function (el) {
            trackAttr(el, attr, el.getAttribute("data-i18n-" + attr));
          });
        });
        ["placeholder", "title", "aria-label", "alt"].forEach(function (attr) {
          document.querySelectorAll("[" + attr + "]").forEach(function (el) {
            var v = el.getAttribute(attr);
            if (v && KNOWN[v.trim()] && !el.hasAttribute("data-i18n-" + attr)) trackAttr(el, attr, v.trim());
          });
        });
        var walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT, null);
        var n;
        while ((n = walker.nextNode())) {
          if (textOrig.has(n)) continue;
          var raw = n.nodeValue; if (!raw) continue;
          var t = raw.trim(); if (!t || !KNOWN[t]) continue;
          if (inSkip(n) || inExplicit(n)) continue;
          textOrig.set(n, { en: t, pre: raw.match(/^\s*/)[0], post: raw.match(/\s*$/)[0] });
          textList.push(n);
        }
      }
      var SHORT = { en: "EN", vi: "VI", zh: "中", "zh-TW": "繁" };
      function updateSwitcher(lang) {
        document.querySelectorAll("[data-lang-btn]").forEach(function (b) {
          var on = b.getAttribute("data-lang-btn") === lang;
          b.classList.toggle("lang-active", on);
          b.setAttribute("aria-pressed", on ? "true" : "false");
        });
        document.querySelectorAll("[data-lang-current]").forEach(function (el) {
          el.textContent = SHORT[lang] || "EN";
        });
      }
      function closeMenu() {
        var m = document.getElementById("lang-menu"); if (m) m.classList.add("hidden");
        var t = document.getElementById("lang-toggle"); if (t) t.setAttribute("aria-expanded", "false");
      }
      function apply(lang) {
        collect();
        elList.forEach(function (el) { el.textContent = tr(lang, el.getAttribute("data-i18n") || ""); });
        attrList.forEach(function (o) { o.el.setAttribute(o.attr, tr(lang, attrOrig.get(o.el)[o.attr])); });
        textList.forEach(function (n) { var o = textOrig.get(n); n.nodeValue = o.pre + tr(lang, o.en) + o.post; });
        document.documentElement.lang = HTML_LANG[lang] || "en";
        updateSwitcher(lang);
      }
      var current = detect();
      function setLang(lang) {
        if (LANGS.indexOf(lang) < 0) return;
        current = lang;
        try { localStorage.setItem(STORE_KEY, lang); } catch (e) {}
        apply(lang);
      }
      document.addEventListener("click", function (e) {
        var node = e.target;
        // Toggle the desktop dropdown.
        var toggle = node.closest ? node.closest("#lang-toggle") : null;
        if (toggle) {
          e.preventDefault();
          var m = document.getElementById("lang-menu");
          if (m) {
            var willOpen = m.classList.contains("hidden");
            m.classList.toggle("hidden");
            toggle.setAttribute("aria-expanded", willOpen ? "true" : "false");
          }
          return;
        }
        // Pick a language.
        var b = node.closest ? node.closest("[data-lang-btn]") : null;
        if (b) {
          e.preventDefault();
          setLang(b.getAttribute("data-lang-btn"));
          closeMenu();
          return;
        }
        // Click outside closes the dropdown.
        if (!(node.closest && node.closest("#lang-switch"))) closeMenu();
      });
      // Expose so dynamically-injected UI (auth menu, etc.) can re-translate.
      window.AP_I18N = { apply: function () { apply(current); }, lang: function () { return current; }, set: setLang };
      apply(current);
    })();
  </script>

  <style is:global>
    /* Desktop dropdown items */
    .lang-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      border-radius: 0.6rem;
      padding: 0.5rem 0.7rem;
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--muted, #6b7280);
      transition: background-color .12s, color .12s;
    }
    .lang-item:hover { background: var(--brand-50, #eff4ff); color: var(--brand-700, #1d4ed8); }
    .lang-item.lang-active { color: var(--brand-700, #1d4ed8); }
    .lang-check { visibility: hidden; }
    .lang-item.lang-active .lang-check { visibility: visible; }
    /* Mobile segmented control */
    .lang-seg {
      border-radius: 0.55rem;
      padding: 0.4rem 0.5rem;
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--muted, #6b7280);
      transition: background-color .12s, color .12s;
    }
    .lang-seg.lang-active { background: #fff; color: var(--brand-700, #1d4ed8); box-shadow: 0 1px 2px rgba(0,0,0,.08); }
    /* Scroll-to-top: hidden until scrolled down */
    #toTop { opacity: 0; transform: translateY(12px); pointer-events: none; transition: opacity .2s ease, transform .2s ease; }
    #toTop.show { opacity: 1; transform: translateY(0); pointer-events: auto; }
  </style>

  <script>
    // Delegated copy-to-clipboard for any [data-copy] button (CodeBlock, etc.).
    document.addEventListener("click", async (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>("[data-copy]");
      if (!btn) return;
      try { await navigator.clipboard.writeText(btn.dataset.copy ?? ""); } catch { return; }
      const copyI = btn.querySelector(".copy-i");
      const checkI = btn.querySelector(".check-i");
      const label = btn.querySelector(".copy-label");
      copyI?.classList.add("hidden");
      checkI?.classList.remove("hidden");
      if (label) label.textContent = "Copied";
      window.setTimeout(() => {
        copyI?.classList.remove("hidden");
        checkI?.classList.add("hidden");
        if (label) label.textContent = "Copy";
      }, 1500);
    });
  </script>

  <script>
    // Auth + likes from ONE authoritative call (/api/me.json => {user, mine}) so the
    // nav and like buttons never drift out of sync. Counts come from cached stats.json.
    (() => {
      let mineSet = new Set<string>();

      function renderAvatar(user: { login: string; avatar: string; isAdmin?: boolean }) {
        const slot = document.getElementById("ap-auth");
        if (!slot) return;
        const login = String(user.login).replace(/[^a-zA-Z0-9-]/g, "");
        const adminLink = user.isAdmin
          ? `<a href="/admin" class="block rounded-xl px-3 py-2 text-sm font-medium text-muted transition hover:bg-brand-50 hover:text-brand-700">Pet admin</a>`
          : "";
        slot.innerHTML = `
          <div class="relative">
            <button id="ap-avatar" type="button" class="flex items-center gap-2 rounded-full border border-line bg-white py-1 pl-1 pr-3 shadow-soft transition hover:border-brand-300">
              <img src="${user.avatar}" alt="" class="h-7 w-7 rounded-full" />
              <span class="hidden text-sm font-semibold text-ink sm:inline">${login}</span>
            </button>
            <div id="ap-menu" class="absolute right-0 z-50 mt-2 hidden w-48 rounded-2xl border border-line bg-white p-2 shadow-card">
              <div class="px-3 py-2 text-xs text-faint">Signed in as <b class="text-ink">${login}</b></div>
              <a href="/profile" class="block rounded-xl px-3 py-2 text-sm font-medium text-muted transition hover:bg-brand-50 hover:text-brand-700">My pets</a>
              ${adminLink}
              <a href="/api/auth/logout" class="block rounded-xl px-3 py-2 text-sm font-medium text-muted transition hover:bg-brand-50 hover:text-brand-700">Sign out</a>
            </div>
          </div>`;
        const btn = document.getElementById("ap-avatar");
        const menu = document.getElementById("ap-menu");
        btn?.addEventListener("click", (e) => { e.stopPropagation(); menu?.classList.toggle("hidden"); });
        document.addEventListener("click", () => menu?.classList.add("hidden"));
        // Re-translate the freshly injected auth menu into the current language.
        (window as any).AP_I18N?.apply?.();
      }

      function setLiked(btn: Element, liked: boolean) {
        const b = btn as HTMLElement;
        b.setAttribute("aria-pressed", liked ? "true" : "false");
        b.style.color = liked ? "var(--color-accent-600)" : "";
        b.style.borderColor = liked ? "var(--color-accent-400)" : "";
        const label = b.querySelector(".ap-like-label");
        if (label) label.textContent = liked ? "Liked" : "Like";
      }
      function setCount(slug: string, n: number) {
        document.querySelectorAll(`[data-like-count][data-slug="${slug}"]`).forEach((el) => { el.textContent = String(n); });
      }
      // Fill counts (cached) + liked state (from mineSet). Re-runnable for lazy lists.
      async function fillLikes() {
        const s: any = await fetch("/api/stats.json").then((r) => r.json()).catch(() => ({}));
        const likes = s.likes || {};
        const installs = s.installs || {};
        const downloads = s.downloads || {};
        document.querySelectorAll("[data-like-count][data-slug]").forEach((el) => {
          el.textContent = String(likes[el.getAttribute("data-slug")!] || 0);
        });
        document.querySelectorAll("[data-install-count][data-slug]").forEach((el) => {
          el.textContent = String(installs[el.getAttribute("data-slug")!] || 0);
        });
        document.querySelectorAll("[data-download-count][data-slug]").forEach((el) => {
          el.textContent = String(downloads[el.getAttribute("data-slug")!] || 0);
        });
        document.querySelectorAll("[data-like-btn][data-slug]").forEach((btn) => setLiked(btn, mineSet.has(btn.getAttribute("data-slug")!)));
      }
      (window as any).apRefreshLikes = fillLikes;

      document.addEventListener("click", async (e) => {
        const btn = (e.target as HTMLElement).closest("[data-like-btn][data-slug]") as HTMLElement | null;
        if (!btn) return;
        e.preventDefault();
        const slug = btn.getAttribute("data-slug")!;
        btn.setAttribute("disabled", "true");
        try {
          const res = await fetch("/api/like", { method: "POST", headers: { "content-type": "application/json" }, body: JSON.stringify({ slug }) });
          if (res.status === 401) { location.href = "/api/auth/login?returnTo=" + encodeURIComponent(location.pathname); return; }
          const d: any = await res.json();
          if (typeof d.likes === "number") setCount(slug, d.likes);
          if (d.liked) mineSet.add(slug); else mineSet.delete(slug);
          setLiked(btn, !!d.liked);
        } catch {}
        finally { btn.removeAttribute("disabled"); }
      });

      (async () => {
        const me: any = await fetch("/api/me.json").then((r) => r.json()).catch(() => ({ user: null, mine: [] }));
        mineSet = new Set(me.mine || []);
        if (me.user) renderAvatar(me.user);
        fillLikes();
      })();
    })();
  </script>
  <SurprisePet />
</body>
</html>

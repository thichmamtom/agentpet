function paw() {
  // classic paw print: a rounded palm pad with four toe beans arced above it
  return `<ellipse cx="12" cy="15.8" rx="5" ry="4.2"/>
    <ellipse cx="5.7" cy="11" rx="1.9" ry="2.5"/>
    <ellipse cx="9.4" cy="7.1" rx="1.85" ry="2.6"/>
    <ellipse cx="14.6" cy="7.1" rx="1.85" ry="2.6"/>
    <ellipse cx="18.3" cy="11" rx="1.9" ry="2.5"/>`;
}
const isFill = name in fill;
const isPaw = name === "paw";
const inner = isPaw ? paw() : isFill ? fill[name] : (stroke[name] ?? "");
---
{isFill || isPaw ? (
  <svg class={cls} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" set:html={inner} />
) : (
  <svg class={cls} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={inner} />
)}

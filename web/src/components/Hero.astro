---
// Shared page hero: eyebrow chip + title (with accent) + lead + optional CTAs.
// Centered by default; the container spans the full max-w-6xl so every page lines
// up with the header and footer.
import Icon from "./Icon.astro";
interface Props {
  eyebrow?: string;
  icon?: string;
  title: string;
  accent?: string;
  lead?: string;
  align?: "center" | "left";
}
const { eyebrow, icon = "sparkles", title, accent, lead, align = "center" } = Astro.props;
const hasCta = Astro.slots.has("default");
const c = align === "center";
---
<section class="px-4 pt-10 pb-2">
  <div class={`mx-auto max-w-6xl ${c ? "text-center" : ""}`}>
    <div class={c ? "mx-auto max-w-3xl" : "max-w-3xl"}>
      {eyebrow && (
        <span class="chip"><Icon name={icon} class="h-4 w-4" /> {eyebrow}</span>
      )}
      <h1 class="mt-5 font-display text-4xl font-bold leading-[1.08] text-ink sm:text-5xl">
        {title}{accent && <> <span class="text-brand-600">{accent}</span></>}
      </h1>
      {lead && (
        <p class={`mt-4 max-w-2xl text-lg text-[#3f4a6b] ${c ? "mx-auto" : ""}`}>{lead}</p>
      )}
      {hasCta && (
        <div class={`mt-7 flex flex-wrap gap-3 ${c ? "justify-center" : ""}`}><slot /></div>
      )}
    </div>
  </div>
</section>

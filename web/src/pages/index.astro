---
import Base from "../layouts/Base.astro";
import Icon from "../components/Icon.astro";
import PetCard from "../components/PetCard.astro";
import CodeBlock from "../components/CodeBlock.astro";

const RELEASE_LATEST = "https://github.com/ntd4996/agentpet/releases/latest";
const BREW = "brew install --cask ntd4996/tap/agentpet";

// Build-time fetch from the private origin (server-side only; the URL lives in
// env and never reaches the client). Sprites are rendered through our same-origin
// proxy (/api/sprite/<slug>) so the source stays hidden.
const ORIGIN = import.meta.env.PETS_ORIGIN || "";
let petCount = 1100;
let pets: { slug: string; name: string }[] = [];
try {
  const res = await fetch(`${ORIGIN}/manifest.json`);
  const data: any = await res.json();
  const list = data.pets ?? [];
  petCount = list.length;
  pets = list.map((p: any) => ({ slug: p.slug, name: p.displayName ?? p.slug }));
} catch {}

const bubbles = pets.slice(0, 10);

// Deterministic placeholder stats (per slug) until the community backend (likes /
// downloads / per-machine usage) is built; descriptions are real (from pet.json).
function fnv(s: string): number { let x = 2166136261; for (let i = 0; i < s.length; i++) { x ^= s.charCodeAt(i); x = Math.imul(x, 16777619) >>> 0; } return x >>> 0; }
const stat = (slug: string, k: string, mod: number, base: number) => (fnv(slug + k) % mod) + base;
async function descOf(slug: string): Promise<string> {
  try { const r = await fetch(`${ORIGIN}/pets/${slug}/pet.json`); const j: any = await r.json(); return (j.description ?? "").toString(); } catch { return ""; }
}
const KINDS = ["creature", "character", "critter", "spirit", "object"];
const TRAITS = ["focused", "mischievous", "sleepy", "cheerful", "brave", "shy", "curious", "chaotic", "loyal", "zen", "sassy", "dreamy"];
async function enrich(p: { slug: string; name: string }) {
  const f = fnv(p.slug);
  const t1 = TRAITS[f % TRAITS.length];
  const t2 = TRAITS[(f >>> 5) % TRAITS.length];
  return {
    slug: p.slug, name: p.name, author: "community",
    no: 100 + (f % 900),
    kind: KINDS[(f >>> 3) % KINDS.length],
    tags: Array.from(new Set([t1, t2])).filter(Boolean),
    featured: f % 4 === 0,
    desc: await descOf(p.slug),
    likes: stat(p.slug, "l", 880, 24),
    downloads: stat(p.slug, "d", 7400, 130),
    usage: stat(p.slug, "u", 2400, 12),
  };
}

function sample<T>(arr: T[], n: number): T[] {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) { const j = Math.floor(Math.random() * (i + 1)); [a[i], a[j]] = [a[j], a[i]]; }
  return a.slice(0, n);
}
// Lightweight enrich (no per-pet description fetch) for the category rows so the
// home page can group the whole library without hundreds of build-time requests.
function lite(p: { slug: string; name: string }) {
  const f = fnv(p.slug);
  const t1 = TRAITS[f % TRAITS.length];
  const t2 = TRAITS[(f >>> 5) % TRAITS.length];
  return {
    slug: p.slug, name: p.name, no: 100 + (f % 900),
    kind: KINDS[(f >>> 3) % KINDS.length],
    featured: f % 4 === 0,
    tags: Array.from(new Set([t1, t2])).filter(Boolean),
    desc: "",
    likes: stat(p.slug, "l", 880, 24),
    downloads: stat(p.slug, "d", 7400, 130),
    usage: stat(p.slug, "u", 2400, 12),
  };
}
const allLite = pets.map(lite);

// 1 random spotlight (with a real description).
const chosen = sample(pets, 1);
const spotlight = chosen[0] ? await enrich(chosen[0]) : null;

// Browse-by-category rows, like a pet shop. Each kind gets a small sample.
const CATS = [
  { key: "creature", title: "Creatures", sub: "Beasts, monsters, and little beings." },
  { key: "character", title: "Characters", sub: "Heroes, mascots, and familiar faces." },
  { key: "critter", title: "Critters", sub: "Tiny companions with big energy." },
  { key: "spirit", title: "Spirits", sub: "Ethereal, glowy, otherworldly pals." },
];
const categories = CATS.map((c) => ({
  ...c,
  pets: sample(allLite.filter((p) => p.kind === c.key), 4),
})).filter((c) => c.pets.length > 0);

// avatars for the community band
const avatars = sample(allLite, 5);
const stats = [
  { n: `${petCount.toLocaleString()}+`, l: "pets to adopt" },
  { n: "7", l: "agents supported" },
  { n: "9", l: "pet animations" },
  { n: "100%", l: "free & open" },
];
const steps = [
  { icon: "download", title: "Get the app", body: "Install AgentPet on macOS in one command (Windows & Linux soon). Free forever." },
  { icon: "paw", title: "Adopt a pet", body: "Pick from thousands of pixel companions, or make and share your own." },
  { icon: "sparkles", title: "Watch it react", body: "Your pet thinks, works, and celebrates right alongside your AI agents." },
];
const bubblePos = [
  "left-[38%] top-2 h-24 w-24",
  "left-6 top-20 h-16 w-16",
  "right-8 top-16 h-20 w-20",
  "left-16 top-44 h-14 w-14",
  "right-6 top-48 h-16 w-16",
  "left-[40%] top-40 h-20 w-20",
  "left-2 bottom-10 h-14 w-14",
  "right-2 bottom-8 h-16 w-16",
  "left-1/3 bottom-2 h-12 w-12",
  "right-1/3 bottom-4 h-12 w-12",
];
---
<Base title="AgentPet · pixel companions for your AI agents" active="">
  <!-- HERO: chibi floating island in the sky -->
  <section class="relative overflow-hidden px-4 pb-6 pt-6">
    <!-- drifting clouds -->
    <img src="/island/cloud2.png" alt="" class="cloud pixel-art left-0 top-12 w-48 opacity-80" style="animation: drift 80s linear infinite" />
    <img src="/island/cloud3.png" alt="" class="cloud pixel-art top-40 w-64" style="animation: drift 110s linear infinite -30s" />
    <img src="/island/cloud4.png" alt="" class="cloud pixel-art left-0 top-4 w-40 opacity-70" style="animation: drift 140s linear infinite -70s" />
    <img src="/island/cloud5.png" alt="" class="cloud pixel-art top-64 w-56 opacity-80" style="animation: drift 95s linear infinite -50s" />

    <!-- headline -->
    <div class="relative z-10 mx-auto max-w-3xl pt-8 text-center">
      <span class="chip"><Icon name="sparkles" class="h-4 w-4" /> Free · Open source · One-command install</span>
      <h1 class="mt-5 font-display text-5xl font-bold leading-[1.05] text-ink sm:text-6xl">
        Adopt a <span class="text-brand-600">pixel companion</span> for your AI agents
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg text-[#3f4a6b]">
        A tiny desktop pet that reacts while Claude Code, Codex, Cursor and friends do the work. Browse {petCount.toLocaleString()}+ pets, or make your own.
      </p>
      <div class="mt-7 flex flex-wrap justify-center gap-3">
        <a href="/install" class="btn-primary !px-6 !py-3.5 text-base"><Icon name="download" /> Get the app</a>
        <a href="/gallery" class="btn-ghost !px-6 !py-3.5 text-base"><Icon name="grid" class="h-5 w-5" /> Browse pets</a>
      </div>
      <div class="mt-5 flex items-center justify-center gap-2 text-sm text-[#5a6685]">
        <Icon name="apple" class="h-4 w-4" /> macOS now · Windows & Linux soon
      </div>
    </div>

    <!-- island stage -->
    <div class="relative z-10 mx-auto mt-2 w-full max-w-5xl">
      <img src="/island/isl-cherry.png" alt="" class="bob pixel-art absolute -left-2 top-6 z-20 w-24 sm:w-36 md:w-44" style="filter: drop-shadow(0 18px 14px rgba(30,58,130,.22)); animation-delay:-0.6s" />
      <img src="/island/isl-snorlax.png" alt="" class="bob-2 pixel-art absolute -left-3 bottom-8 z-20 w-20 sm:w-32 md:w-40" style="filter: drop-shadow(0 18px 14px rgba(30,58,130,.22)); animation-delay:-2.4s" />
      <img src="/island/isl-chest.png" alt="" class="bob-3 pixel-art absolute -right-1 top-24 z-20 w-20 sm:w-28 md:w-32" style="filter: drop-shadow(0 18px 14px rgba(30,58,130,.22)); animation-delay:-1.5s" />
      <img src="/island/sprout.png" alt="" class="bob pixel-art absolute right-16 bottom-2 z-20 hidden w-12 sm:block" style="animation-delay:-3.2s" />
      <img src="/island/main.png" alt="AgentPet adoption island" class="bob-slow pixel-art relative z-10 mx-auto w-full max-w-4xl" style="filter: drop-shadow(0 30px 24px rgba(30,58,130,.28)); animation-delay:-1.1s" />
    </div>
  </section>

  <!-- STATS -->
  <section class="px-4">
    <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-center gap-x-12 gap-y-4 rounded-card bg-white px-8 py-6 shadow-soft">
      {stats.map((s) => (
        <div class="text-center">
          <div class="font-display text-3xl font-bold text-brand-600">{s.n}</div>
          <div class="text-sm text-muted">{s.l}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- SPOTLIGHT: one random pet of the moment -->
  {spotlight && (
  <section class="px-4 pt-16">
    <div class="mx-auto max-w-6xl">
      <div class="mb-3 flex items-center justify-between gap-2 px-1">
        <div class="flex items-center gap-2">
          <Icon name="sparkles" class="h-5 w-5 text-accent-500" />
          <h2 class="font-display text-2xl font-bold text-ink">Random pick of the moment</h2>
        </div>
        <button id="shuffleBtn" type="button" class="btn-ghost !px-4 !py-2 text-sm">
          <Icon name="shuffle" class="h-4 w-4 transition" /> Shuffle
        </button>
      </div>
      <div class="card grid overflow-hidden md:grid-cols-[340px_1fr]">
        <div class="relative grid place-items-center border-b border-line bg-white p-8 md:border-b-0 md:border-r">
          <span class="absolute left-4 top-4 inline-flex items-center gap-1 rounded-full bg-accent-500 px-3 py-1 text-xs font-bold text-white shadow">
            <Icon name="sparkles" class="h-3.5 w-3.5" /> Random pick
          </span>
          <canvas id="spotCanvas" class="thumb h-52 w-48" width="200" height="240" data-sheet={`/api/sprite/${spotlight.slug}`}></canvas>
        </div>
        <div class="p-7 md:p-9">
          <h3 id="spotName" class="font-display text-3xl font-bold text-ink">{spotlight.name}</h3>
          <div class="mt-1 flex items-center gap-2 text-sm text-faint">
            <span class="grid h-6 w-6 place-items-center rounded-full bg-brand-100 text-brand-700"><Icon name="paw" class="h-3.5 w-3.5" /></span>
            by {spotlight.author}
          </div>
          <p id="spotDesc" class="mt-4 max-w-xl text-muted">{spotlight.desc || "A delightful community pixel companion, ready to live on your desktop."}</p>
          <div class="mt-6 flex flex-wrap gap-x-8 gap-y-3">
            <div>
              <div class="flex items-center gap-1.5 font-display text-2xl font-bold text-ink"><Icon name="heart" class="h-5 w-5 text-accent-500" /><span id="spotLikes">{spotlight.likes}</span></div>
              <div class="text-xs text-faint">likes</div>
            </div>
            <div>
              <div class="flex items-center gap-1.5 font-display text-2xl font-bold text-ink"><Icon name="download" class="h-5 w-5 text-brand-500" /><span id="spotDownloads">{spotlight.downloads.toLocaleString()}</span></div>
              <div class="text-xs text-faint">downloads</div>
            </div>
            <div>
              <div class="flex items-center gap-1.5 font-display text-2xl font-bold text-ink"><Icon name="monitor" class="h-5 w-5 text-emerald-500" /><span id="spotUsage">{spotlight.usage.toLocaleString()}</span></div>
              <div class="text-xs text-faint">in use now</div>
            </div>
          </div>
          <div class="mt-7 flex flex-wrap gap-3">
            <a id="spotAdopt" href={`/pet/${spotlight.slug}`} class="btn-primary !px-6 !py-3"><Icon name="paw" class="h-5 w-5" /> Adopt this pet</a>
            <a href="/gallery" class="btn-ghost !px-6 !py-3"><Icon name="grid" class="h-5 w-5" /> More pets</a>
          </div>
        </div>
      </div>
    </div>
  </section>
  )}

  <!-- BROWSE BY CATEGORY -->
  <section class="px-4 pt-16">
    <div class="mx-auto max-w-6xl">
      <div class="flex items-end justify-between">
        <div>
          <h2 class="font-display text-3xl font-bold text-ink">Browse by category</h2>
          <p class="mt-1 text-muted">A peek at the community library, sorted into shelves.</p>
        </div>
        <a href="/gallery" class="hidden items-center gap-1 font-semibold text-brand-600 hover:text-brand-700 sm:flex">See all {petCount.toLocaleString()}+ <Icon name="arrow" class="h-4 w-4" /></a>
      </div>

      <div class="mt-8 space-y-12">
        {categories.map((c) => (
          <div>
            <div class="mb-4 flex items-end justify-between gap-2 px-1">
              <div>
                <h3 class="font-display text-xl font-bold text-ink">{c.title}</h3>
                <p class="text-sm text-muted">{c.sub}</p>
              </div>
              <a href="/gallery" class="inline-flex items-center gap-1 text-sm font-semibold text-brand-600 hover:text-brand-700">See all <Icon name="arrow" class="h-4 w-4" /></a>
            </div>
            <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
              {c.pets.map((p) => <PetCard pet={p} />)}
            </div>
          </div>
        ))}
      </div>

      <!-- browse-all banner -->
      <a href="/gallery" class="group relative mt-12 flex items-center justify-center gap-4 overflow-hidden rounded-card bg-gradient-to-br from-brand-500 to-brand-600 px-8 py-10 text-center text-white shadow-card transition hover:-translate-y-1">
        <img src="/island/cloud3.png" alt="" class="pixel-art pointer-events-none absolute -right-4 -top-4 w-32 opacity-25 transition-transform duration-700 group-hover:translate-x-3" />
        <img src="/island/cloud5.png" alt="" class="pixel-art pointer-events-none absolute -bottom-4 -left-4 w-32 opacity-20 transition-transform duration-700 group-hover:-translate-x-3" />
        <span class="relative grid h-14 w-14 place-items-center rounded-2xl bg-white/20 ring-1 ring-white/30 transition group-hover:scale-110"><Icon name="search" class="h-7 w-7 text-white" /></span>
        <div class="relative text-left">
          <div class="font-display text-2xl font-bold leading-tight">Browse all {petCount.toLocaleString()}+ pets</div>
          <span class="inline-flex items-center gap-1 text-sm font-semibold text-brand-100">Open the full gallery <Icon name="arrow" class="h-4 w-4 transition group-hover:translate-x-1.5" /></span>
        </div>
      </a>
    </div>
  </section>

  <!-- WORLD SHOWCASE -->
  <section class="relative px-4 pt-20">
    <div class="mx-auto max-w-6xl text-center">
      <div class="font-pixel text-[11px] uppercase tracking-wide text-brand-500">The AgentPet world</div>
      <h2 class="mt-2 font-display text-3xl font-bold text-ink sm:text-4xl">One island, every companion</h2>
      <p class="mx-auto mt-3 max-w-2xl text-muted">From Totoro to Pikachu to your own creations, the whole community lives on one cozy floating island, hanging out while your agents work.</p>
      <div class="relative mt-6">
        <img src="/art/pet-island-sign.webp" alt="" class="bob-3 pointer-events-none absolute -left-2 top-6 z-20 hidden w-24 -rotate-6 sm:block md:w-28" style="filter: drop-shadow(0 10px 10px rgba(30,58,130,.20)); animation-delay:-1.1s" />
        <img src="/art/island-world.webp" alt="A floating island full of pixel companions" class="bob-slow relative z-10 mx-auto w-full max-w-3xl" style="filter: drop-shadow(0 12px 26px rgba(30,58,130,.22))" />
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="px-4 pt-16">
    <div class="mx-auto max-w-6xl">
      <h2 class="text-center font-display text-3xl font-bold text-ink">Three steps to a happy desktop</h2>
      <div class="mt-8 grid gap-5 md:grid-cols-3">
        {steps.map((s, i) => (
          <div class="card p-7">
            <div class="grid h-12 w-12 place-items-center rounded-2xl bg-brand-50 text-brand-600"><Icon name={s.icon} class="h-6 w-6" /></div>
            <div class="mt-4 font-display text-xs font-bold uppercase tracking-wide text-brand-500">Step {i + 1}</div>
            <h3 class="mt-1 font-display text-xl font-semibold text-ink">{s.title}</h3>
            <p class="mt-2 text-muted">{s.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- INSTALL -->
  <section class="px-4 pt-20">
    <div class="relative mx-auto max-w-6xl overflow-hidden rounded-[2rem] border border-line bg-white px-8 py-12 shadow-card">
      <img src="/island/cloud4.png" alt="" class="pixel-art pointer-events-none absolute -right-6 -top-6 w-40 opacity-50" />
      <div class="relative grid items-center gap-8 md:grid-cols-[1.1fr_1fr]">
        <div>
          <div class="font-pixel text-[11px] uppercase tracking-wide text-brand-500">Install in seconds</div>
          <h2 class="mt-2 font-display text-3xl font-bold text-ink sm:text-4xl">Up and running with one command</h2>
          <p class="mt-3 max-w-md text-muted">AgentPet is free, open source, and notarized by Apple. Install it on macOS with Homebrew or a direct download. Windows and Linux are on the way.</p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href="/install" class="btn-primary !px-6 !py-3"><Icon name="apple" class="h-5 w-5" /> Download for macOS</a>
            <a href="/install#uninstall" class="btn-ghost !px-6 !py-3"><Icon name="book" class="h-5 w-5" /> Install &amp; uninstall guide</a>
          </div>
        </div>
        <div>
          <CodeBlock code={BREW} />
          <p class="mt-2 text-sm text-faint">Then open Settings and connect your agent. That's it.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- COMMUNITY / DISCORD -->
  <section class="px-4 pt-20">
    <div class="relative mx-auto max-w-6xl overflow-hidden rounded-[2rem] bg-gradient-to-br from-brand-600 via-brand-500 to-brand-500 px-8 py-16 text-center shadow-card">
      <img src="/island/isl-cherry.png" alt="" class="bob pixel-art absolute -left-4 bottom-2 hidden w-28 opacity-90 md:block" />
      <img src="/island/isl-chest.png" alt="" class="bob-2 pixel-art absolute -right-3 bottom-4 hidden w-24 opacity-90 md:block" />
      <div class="relative">
        <div class="mb-7 flex flex-wrap justify-center gap-3">
          {avatars.map((p, i) => (
            <span class="grid h-16 w-16 place-items-center rounded-2xl border-2 border-white/70 bg-white shadow-lg" style={`transform: rotate(${[-5, 4, -2, 5, -4][i]}deg)`}>
              <canvas class="thumb h-12 w-12" width="96" height="96" data-autoplay data-sheet={`/api/sprite/${p.slug}`}></canvas>
            </span>
          ))}
        </div>
        <h2 class="font-display text-4xl font-bold text-white">Join the pack</h2>
        <p class="mx-auto mt-3 max-w-lg text-brand-100">Share pets, request features, and hang out with other terminal dwellers on Discord.</p>
        <div class="mt-7 flex flex-wrap justify-center gap-3">
          <a href="https://discord.gg/kzFJKsZav" target="_blank" rel="noopener" class="btn !bg-white !px-6 !py-3.5 text-base font-semibold text-brand-700 transition hover:-translate-y-0.5"><Icon name="discord" class="h-5 w-5" /> Join our Discord</a>
          <a href="/make" class="btn !px-6 !py-3.5 text-base font-semibold text-white transition hover:-translate-y-0.5" style="border:1px solid rgba(255,255,255,.5)"><Icon name="wand" class="h-5 w-5" /> Make a pet</a>
        </div>
      </div>
    </div>
  </section>

  <script>
    // Slice a spritesheet (alpha gutters) into rows=animations, play one row on a
    // canvas. Spotlight ([data-autoplay]) loops automatically; cards play on hover.
    // Same-origin (/api/sprite) so getImageData isn't blocked.
    type Frame = { x: number; y: number; w: number; h: number };
    function seg(arr: boolean[]): [number, number][] {
      const r: [number, number][] = []; let s: number | null = null;
      for (let i = 0; i < arr.length; i++) { if (arr[i] && s === null) s = i; else if (!arr[i] && s !== null) { r.push([s, i]); s = null; } }
      if (s !== null) r.push([s, arr.length]); return r;
    }
    function sliceRows(img: HTMLImageElement): Frame[][] | null {
      const w = img.naturalWidth, h = img.naturalHeight, TH = 16;
      const off = document.createElement("canvas"); off.width = w; off.height = h;
      const o = off.getContext("2d")!; o.drawImage(img, 0, 0);
      let px: Uint8ClampedArray;
      try { px = o.getImageData(0, 0, w, h).data; } catch { return null; }
      const rowHas: boolean[] = new Array(h).fill(false);
      for (let y = 0; y < h; y++) { const b = y * w * 4; for (let x = 0; x < w; x++) if (px[b + x * 4 + 3] > TH) { rowHas[y] = true; break; } }
      const rows: Frame[][] = [];
      for (const [y0, y1] of seg(rowHas)) {
        const colHas: boolean[] = new Array(w).fill(false);
        for (let x = 0; x < w; x++) for (let y = y0; y < y1; y++) if (px[(y * w + x) * 4 + 3] > TH) { colHas[x] = true; break; }
        const frames = seg(colHas).map(([x0, x1]) => ({ x: x0, y: y0, w: x1 - x0, h: y1 - y0 }));
        if (frames.length) rows.push(frames);
      }
      return rows;
    }
    function makeCanvas(cv: HTMLCanvasElement, opts: { autoplay?: boolean; hover?: boolean; fill?: number }) {
      const ctx = cv.getContext("2d")!; ctx.imageSmoothingEnabled = false;
      const fill = opts.fill ?? (opts.autoplay ? 0.96 : 0.58);
      let img = new Image(); let frames: Frame[] = []; let idx = 0; let timer: number | null = null;
      const draw = (f: Frame) => {
        ctx.clearRect(0, 0, cv.width, cv.height);
        const s = Math.min(cv.width / f.w, cv.height / f.h) * fill, dw = f.w * s, dh = f.h * s;
        ctx.drawImage(img, f.x, f.y, f.w, f.h, (cv.width - dw) / 2, (cv.height - dh) / 2, dw, dh);
      };
      const play = () => { if (timer || frames.length < 2) return; timer = window.setInterval(() => { idx = (idx + 1) % frames.length; draw(frames[idx]); }, 150); };
      const stop = () => { if (timer) { clearInterval(timer); timer = null; } idx = 0; if (frames[0]) draw(frames[0]); };
      const load = (url: string) => {
        stop(); frames = []; img = new Image();
        img.onload = () => {
          const rows = sliceRows(img); if (!rows || !rows.length) return;
          const sEl = cv.closest("a")?.querySelector<HTMLElement>(".states");
          if (sEl) sEl.textContent = rows.length + (rows.length === 1 ? " state" : " states");
          frames = rows.flat(); idx = 0; draw(frames[0]);
          if (opts.autoplay) play();
        };
        img.src = url;
      };
      if (opts.hover) { const host = (cv.closest("a") ?? cv.parentElement)!; host.addEventListener("mouseenter", play); host.addEventListener("mouseleave", stop); }
      return { load, play, stop };
    }

    // Grid cards (+ pack avatars). Spotlight is handled separately so Shuffle can reload it.
    document.querySelectorAll<HTMLCanvasElement>("canvas.thumb:not(#spotCanvas)").forEach((cv) => {
      const autoplay = cv.hasAttribute("data-autoplay");
      makeCanvas(cv, { autoplay, hover: !autoplay }).load(cv.dataset.sheet!);
    });

    // Spotlight + Shuffle
    const spotCanvas = document.getElementById("spotCanvas") as HTMLCanvasElement | null;
    const spot = spotCanvas ? makeCanvas(spotCanvas, { autoplay: true, fill: 0.96 }) : null;
    if (spotCanvas && spot) spot.load(spotCanvas.dataset.sheet!);

    const setText = (id: string, t: string) => { const el = document.getElementById(id); if (el) el.textContent = t; };
    const shuffleBtn = document.getElementById("shuffleBtn") as HTMLButtonElement | null;
    shuffleBtn?.addEventListener("click", async () => {
      shuffleBtn.disabled = true; shuffleBtn.classList.add("opacity-60");
      shuffleBtn.querySelector("svg")?.animate([{ transform: "rotate(0)" }, { transform: "rotate(360deg)" }], { duration: 450, easing: "ease" });
      try {
        const d: any = await (await fetch("/api/random-pet.json")).json();
        if (d && d.slug) {
          setText("spotName", d.name);
          setText("spotDesc", d.desc || "A delightful community pixel companion, ready to live on your desktop.");
          setText("spotLikes", String(d.likes));
          setText("spotDownloads", Number(d.downloads).toLocaleString());
          setText("spotUsage", Number(d.usage).toLocaleString());
          document.getElementById("spotAdopt")?.setAttribute("href", "/pet/" + d.slug);
          spot?.load("/api/sprite/" + d.slug);
        }
      } catch {}
      finally { shuffleBtn.disabled = false; shuffleBtn.classList.remove("opacity-60"); }
    });
  </script>
</Base>

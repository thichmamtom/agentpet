---
import Base from "../../layouts/Base.astro";
import Icon from "../../components/Icon.astro";
import { loadManifest, applyOverrides, petsBase } from "../../lib/pets";
import { getDB, ensureSchema, getOverrides, collectionsForPet, getNumber } from "../../lib/db";

export const prerender = false;

const { slug = "" } = Astro.params;

// pet.json carries displayName + description + category + submittedBy.
let pet: any = null;
try { pet = await (await fetch(`${petsBase()}/pets/${slug}/pet.json`)).json(); } catch {}
if (!pet || !pet.displayName) return Astro.redirect("/gallery");

// Ordered, override-aware list for prev/next + real kind/author.
const db = getDB();
let ovr = {};
if (db) { await ensureSchema(db); ovr = await getOverrides(db); }
const all = applyOverrides(await loadManifest(), ovr);
const inCollections = db ? await collectionsForPet(db, slug) : [];
const petNum = db ? await getNumber(db, slug) : null;
const noLabel = petNum ? String(petNum).padStart(5, "0") : "—";
const idx = all.findIndex((p) => p.slug === slug);
const entry = idx >= 0 ? all[idx] : null;
const prev = all.length ? (idx > 0 ? all[idx - 1] : all[all.length - 1]) : null;
const next = all.length ? (idx >= 0 && idx < all.length - 1 ? all[idx + 1] : all[0]) : null;

function fnv(s: string): number { let x = 2166136261; for (let i = 0; i < s.length; i++) { x ^= s.charCodeAt(i); x = Math.imul(x, 16777619) >>> 0; } return x >>> 0; }
const f = fnv(slug);
const TRAITS = ["focused", "mischievous", "sleepy", "cheerful", "brave", "shy", "curious", "chaotic", "loyal", "zen", "sassy", "dreamy"];
const kind = entry?.kind || pet.category || "creature";
const author = String(entry?.submittedBy || pet.submittedBy || "").trim() || "community";
const tags = Array.from(new Set([TRAITS[f % TRAITS.length], TRAITS[(f >>> 5) % TRAITS.length]])).filter(Boolean);
const featured = f % 4 === 0;
const GITHUB = "https://github.com/ntd4996/agentpet";

// Dex stats radar geometry (fixed; the data polygon is drawn client-side).
const RADAR = { cx: 120, cy: 120, r: 90 };
const AXES = [
  { key: "loved", label: "Loved", ang: -90, color: "#f43f5e" },
  { key: "popular", label: "Popular", ang: 0, color: "#2563eb" },
  { key: "animated", label: "Animated", ang: 90, color: "#10b981" },
  { key: "states", label: "States", ang: 180, color: "#f59e0b" },
];
const rpt = (ang: number, rad: number): [number, number] => { const a = (ang * Math.PI) / 180; return [RADAR.cx + Math.cos(a) * rad, RADAR.cy + Math.sin(a) * rad]; };
const rings = [0.25, 0.5, 0.75, 1].map((f) => AXES.map((a) => rpt(a.ang, RADAR.r * f).map((n) => n.toFixed(1)).join(",")).join(" "));
const spokes = AXES.map((a) => rpt(a.ang, RADAR.r));
const axisLabels = AXES.map((a) => ({ ...a, p: rpt(a.ang, RADAR.r + 17) }));
---
<Base title={`${pet.displayName} · AgentPet`} description={pet.description} active="gallery">
  <section class="px-4 pt-8 pb-4">
    <div class="mx-auto max-w-6xl">
      <!-- top nav: back + prev/next/shuffle -->
      <div class="flex items-center justify-between gap-2">
        <a href="/gallery" class="group inline-flex items-center gap-2 rounded-full border border-line bg-white/80 py-1.5 pl-1.5 pr-4 text-sm font-semibold text-muted shadow-soft backdrop-blur transition hover:border-brand-300 hover:text-brand-700">
          <span class="grid h-7 w-7 place-items-center rounded-full bg-brand-50 text-brand-600 transition group-hover:-translate-x-0.5"><Icon name="arrow" class="h-4 w-4 rotate-180" /></span>
          Back to gallery
        </a>
        <div class="flex items-center gap-2">
          {prev && <a id="navPrev" href={`/pet/${prev.slug}`} title={`Previous: ${prev.name}`} class="grid h-9 w-9 place-items-center rounded-full border border-line bg-white text-muted shadow-soft transition hover:border-brand-300 hover:text-brand-700"><Icon name="arrow" class="h-4 w-4 rotate-180" /></a>}
          <button id="shuffleBtn" type="button" class="btn-ghost !px-4 !py-2 text-sm"><Icon name="shuffle" class="h-4 w-4" /> Shuffle</button>
          {next && <a id="navNext" href={`/pet/${next.slug}`} title={`Next: ${next.name}`} class="grid h-9 w-9 place-items-center rounded-full border border-line bg-white text-muted shadow-soft transition hover:border-brand-300 hover:text-brand-700"><Icon name="arrow" class="h-4 w-4" /></a>}
        </div>
      </div>

      <!-- header: live state preview + pet meta -->
      <div class="card mt-4 grid overflow-hidden md:grid-cols-[380px_1fr]">
        <div class="relative flex flex-col border-b border-line bg-white md:border-b-0 md:border-r">
          <div class="flex items-center justify-between px-6 pt-5 font-pixel text-[11px] tracking-wide text-faint">
            <span>NO. {noLabel}</span>
            {featured
              ? <span class="inline-flex items-center gap-1 text-brand-600"><Icon name="star" class="h-3 w-3" /> FEATURED</span>
              : <span class="uppercase">{kind}</span>}
          </div>
          <!-- checker-backed preview, like a sprite editor canvas -->
          <div class="relative mx-6 mt-3 grid place-items-center rounded-2xl border border-line p-4 sprite-checker">
            <canvas id="mainCanvas" class="h-56 w-full cursor-pointer" width="320" height="260" data-sheet={`/api/sprite/${slug}`} title="Tap to cycle states"></canvas>
            <span class="pointer-events-none absolute bottom-2 right-2 rounded-full bg-white/85 px-2 py-0.5 font-pixel text-[9px] tracking-wide text-faint shadow-sm">TAP TO CYCLE</span>
          </div>
          <div class="px-6 pb-5 pt-4">
            <div class="flex items-center justify-between">
              <div class="font-display text-lg font-bold text-ink" id="viewerState">Idle</div>
              <span class="inline-flex items-center gap-1.5 rounded-full bg-brand-50 px-3 py-1 font-pixel text-[11px] tracking-wide text-brand-700">
                <Icon name="bolt" class="h-3.5 w-3.5" /> <span id="viewerFrames">…</span>
              </span>
            </div>
            <p class="mt-1 text-sm text-muted" id="viewerCaption">Neutral breathing and blinking loop.</p>
          </div>
        </div>

        <div class="p-7 md:p-9">
          <div class="flex flex-wrap items-center gap-3">
            <h1 class="font-display text-4xl font-bold text-ink">{pet.displayName}</h1>
            <span class="font-pixel text-[11px] uppercase tracking-wide text-faint">{kind}</span>
          </div>
          <div class="mt-2 flex items-center gap-2 text-sm text-faint">
            <span class="grid h-6 w-6 place-items-center rounded-full bg-brand-100 text-brand-700"><Icon name="paw" class="h-3.5 w-3.5" /></span>
            by {author}
          </div>
          <div class="mt-3 flex flex-wrap gap-1.5">
            {tags.map((t) => <span class="rounded-full bg-brand-50 px-2.5 py-0.5 font-pixel text-[10px] lowercase text-brand-700">#{t}</span>)}
          </div>
          <p class="mt-4 max-w-xl text-muted">{pet.description}</p>
          {inCollections.length > 0 && (
            <div class="mt-4 flex flex-wrap items-center gap-2">
              <span class="font-pixel text-[10px] uppercase tracking-wide text-faint">Part of</span>
              {inCollections.map((c) => <a href={`/collections/${c.slug}`} class="rounded-full border border-line bg-white px-3 py-1 text-xs font-semibold text-brand-700 transition hover:border-brand-300">{c.title}</a>)}
            </div>
          )}
          <div class="mt-6 flex flex-wrap gap-x-8 gap-y-3">
            <div><div class="flex items-center gap-1.5 font-display text-2xl font-bold text-ink"><Icon name="heart" class="h-5 w-5 text-accent-500" /><span data-like-count data-slug={slug}>0</span></div><div class="text-xs text-faint">likes</div></div>
            <div><div class="flex items-center gap-1.5 font-display text-2xl font-bold text-ink"><Icon name="download" class="h-5 w-5 text-brand-500" /><span data-install-count data-slug={slug}>0</span></div><div class="text-xs text-faint">installs</div></div>
          </div>
          <div class="mt-7 flex flex-wrap gap-3">
            <a href="/install" class="btn-primary !px-6 !py-3"><Icon name="download" class="h-5 w-5" /> Adopt in AgentPet</a>
            <button type="button" data-like-btn data-slug={slug} aria-pressed="false" class="ap-like btn-ghost !px-6 !py-3"><Icon name="heart" class="ap-like-icon h-5 w-5" /> <span class="ap-like-label">Like</span></button>
            <button type="button" id="shareBtn" class="btn-ghost !px-5 !py-3"><Icon name="share" class="h-4 w-4" /> <span id="shareLabel">Share</span></button>
            <a href={GITHUB} target="_blank" rel="noopener" class="btn-ghost !px-5 !py-3"><Icon name="github" class="h-4 w-4" /> Source</a>
          </div>
        </div>
      </div>

      <!-- dex stats: a radar chart from real signals (likes, installs, frames, states) -->
      <div class="card mt-6 p-6" id="dexStats" data-slug={slug}>
        <div class="mb-2 flex items-center gap-2">
          <span class="grid h-8 w-8 place-items-center rounded-xl bg-brand-50 text-brand-600"><Icon name="bolt" class="h-4 w-4" /></span>
          <h2 class="font-display text-xl font-bold text-ink">Dex stats</h2>
        </div>
        <div class="grid items-center gap-6 sm:grid-cols-[1fr_1fr]">
          <svg viewBox="-26 -22 292 284" class="mx-auto w-full max-w-[280px]">
            <g fill="none" stroke="var(--color-line)" stroke-width="1">
              {rings.map((pts) => <polygon points={pts} />)}
              {spokes.map(([x, y]) => <line x1={RADAR.cx} y1={RADAR.cy} x2={x.toFixed(1)} y2={y.toFixed(1)} />)}
            </g>
            <polygon id="dexPoly" points={`${RADAR.cx},${RADAR.cy}`} fill="rgba(37,99,235,.16)" stroke="#2563eb" stroke-width="2" stroke-linejoin="round" class="transition-all duration-700" />
            <g id="dexDots"></g>
            {axisLabels.map((a) => (
              <text x={a.p[0].toFixed(1)} y={a.p[1].toFixed(1)} text-anchor="middle" dominant-baseline="middle" class="fill-faint font-pixel" style="font-size:9px;letter-spacing:.04em">{a.label.toUpperCase()}</text>
            ))}
          </svg>
          <div class="grid gap-2.5">
            {AXES.map((a) => (
              <div class="flex items-center gap-2.5">
                <span class="h-3 w-3 shrink-0 rounded-full" style={`background:${a.color}`}></span>
                <span class="flex-1 text-sm text-muted">{a.label}</span>
                <span data-stat-val={a.key} class="font-display text-lg font-bold text-ink">0</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- state viewer: every animation in the pack, click to preview -->
      <div class="mt-8">
        <div class="mb-3 flex items-center justify-between gap-2 px-1">
          <div class="flex items-center gap-2">
            <Icon name="grid" class="h-5 w-5 text-brand-500" />
            <h2 class="font-display text-2xl font-bold text-ink">State viewer</h2>
          </div>
          <span class="font-pixel text-[12px] tracking-wide text-faint"><span id="stateCount">…</span> states</span>
        </div>
        <div id="stateGrid" class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          <div class="card p-5 text-sm text-muted">Loading animations…</div>
        </div>
      </div>

      <!-- similar pets -->
      <div class="mt-10" id="similarWrap" data-slug={slug} data-kind={kind}>
        <div class="mb-3 flex items-center gap-2 px-1">
          <Icon name="sparkles" class="h-5 w-5 text-brand-500" />
          <h2 class="font-display text-2xl font-bold text-ink">More like this</h2>
        </div>
        <div id="similarGrid" class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5"></div>
      </div>

      <!-- footer note -->
      <div class="mt-10 grid gap-4 sm:grid-cols-2">
        <div class="card flex items-start gap-3 p-5">
          <span class="grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-brand-50 text-brand-600"><Icon name="bolt" class="h-5 w-5" /></span>
          <div>
            <div class="font-display font-semibold text-ink">One-click adopt</div>
            <p class="mt-0.5 text-sm text-muted">Open this pet in AgentPet to install it on your desktop instantly.</p>
          </div>
        </div>
        <div class="card flex items-start gap-3 p-5">
          <span class="grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-brand-50 text-brand-600"><Icon name="monitor" class="h-5 w-5" /></span>
          <div>
            <div class="font-display font-semibold text-ink">Local-first</div>
            <p class="mt-0.5 text-sm text-muted">Pets live on your machine and react over a local socket. No telemetry.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    // Slice the spritesheet (alpha gutters) into rows = animation states, then drive
    // a State Viewer: the header plays the SELECTED state; the grid previews EVERY
    // state animating at once and lets you switch.
    type Frame = { x: number; y: number; w: number; h: number };
    const NAMES = ["Idle", "Run Right", "Run Left", "Waving", "Jumping", "Failed", "Waiting", "Running", "Review"];
    const CAPTIONS: Record<string, string> = {
      "Idle": "Neutral breathing and blinking loop.",
      "Run Right": "Dashing across to the right edge.",
      "Run Left": "Scurrying back to the left.",
      "Waving": "A friendly hello when you check in.",
      "Jumping": "An excited little hop of celebration.",
      "Failed": "A small slump when something errors out.",
      "Waiting": "Standing by for your next move.",
      "Running": "Heads-down and busy while an agent works.",
      "Review": "Looking things over, reviewing the changes.",
    };

    function seg(arr: boolean[]) { const r: [number, number][] = []; let s: number | null = null; for (let i = 0; i < arr.length; i++) { if (arr[i] && s === null) s = i; else if (!arr[i] && s !== null) { r.push([s, i]); s = null; } } if (s !== null) r.push([s, arr.length]); return r; }
    function sliceRows(img: HTMLImageElement) {
      const w = img.naturalWidth, h = img.naturalHeight, TH = 16;
      const off = document.createElement("canvas"); off.width = w; off.height = h;
      const o = off.getContext("2d")!; o.drawImage(img, 0, 0);
      let px: Uint8ClampedArray; try { px = o.getImageData(0, 0, w, h).data; } catch { return null; }
      const rowHas: boolean[] = new Array(h).fill(false);
      for (let y = 0; y < h; y++) { const b = y * w * 4; for (let x = 0; x < w; x++) if (px[b + x * 4 + 3] > TH) { rowHas[y] = true; break; } }
      const rows: Frame[][] = [];
      for (const [y0, y1] of seg(rowHas)) {
        const colHas: boolean[] = new Array(w).fill(false);
        for (let x = 0; x < w; x++) for (let y = y0; y < y1; y++) if (px[(y * w + x) * 4 + 3] > TH) { colHas[x] = true; break; }
        const fr = seg(colHas).map(([x0, x1]) => ({ x: x0, y: y0, w: x1 - x0, h: y1 - y0 }));
        if (fr.length) rows.push(fr);
      }
      return rows;
    }
    function drawFrame(ctx: CanvasRenderingContext2D, cv: HTMLCanvasElement, img: HTMLImageElement, f: Frame, fill: number) {
      ctx.clearRect(0, 0, cv.width, cv.height);
      const s = Math.min(cv.width / f.w, cv.height / f.h) * fill, dw = f.w * s, dh = f.h * s;
      ctx.drawImage(img, f.x, f.y, f.w, f.h, (cv.width - dw) / 2, (cv.height - dh) / 2, dw, dh);
    }

    // Dex stats radar. Values are 0-100; `sat` is a saturating curve for unbounded
    // counts (likes/installs). Geometry mirrors the SVG grid (cx120 cy120 r90).
    const DEX_AX = [
      { key: "loved", ang: -90, color: "#f43f5e" },
      { key: "popular", ang: 0, color: "#2563eb" },
      { key: "animated", ang: 90, color: "#10b981" },
      { key: "states", ang: 180, color: "#f59e0b" },
    ];
    const DEX = { cx: 120, cy: 120, r: 90 };
    const dexVals: Record<string, number> = { loved: 0, popular: 0, animated: 0, states: 0 };
    const dexLabel: Record<string, string | number> = { loved: 0, popular: 0, animated: 0, states: 0 };
    const dpt = (ang: number, rad: number): [number, number] => { const a = (ang * Math.PI) / 180; return [DEX.cx + Math.cos(a) * rad, DEX.cy + Math.sin(a) * rad]; };
    function renderRadar() {
      const poly = document.getElementById("dexPoly"); if (!poly) return;
      const dots = document.getElementById("dexDots");
      const pts = DEX_AX.map((a) => dpt(a.ang, DEX.r * Math.max(0, Math.min(100, dexVals[a.key])) / 100));
      poly.setAttribute("points", pts.map((p) => p.map((n) => n.toFixed(1)).join(",")).join(" "));
      if (dots) dots.innerHTML = pts.map((p, i) => `<circle cx="${p[0].toFixed(1)}" cy="${p[1].toFixed(1)}" r="3.5" fill="${DEX_AX[i].color}" />`).join("");
      for (const a of DEX_AX) { const el = document.querySelector(`[data-stat-val="${a.key}"]`); if (el) el.textContent = String(dexLabel[a.key]); }
    }
    function setStat(key: string, pct: number, label: string | number) { dexVals[key] = pct; dexLabel[key] = label; renderRadar(); }
    const sat = (n: number) => Math.round(100 * (1 - 1 / (1 + n / 6)));
    const dex = document.getElementById("dexStats");
    if (dex) {
      const dslug = dex.dataset.slug!;
      fetch("/api/stats.json").then((r) => r.json()).then((s: any) => {
        const likes = (s.likes || {})[dslug] || 0, installs = (s.installs || {})[dslug] || 0;
        setStat("loved", sat(likes), likes);
        setStat("popular", sat(installs), installs);
      }).catch(() => {});
    }

    const main = document.getElementById("mainCanvas") as HTMLCanvasElement | null;
    const grid = document.getElementById("stateGrid");
    if (main && grid) {
      const mctx = main.getContext("2d")!; mctx.imageSmoothingEnabled = false;
      const img = new Image();
      let rows: Frame[][] = [];
      let timer: number | null = null;
      let cur = 0;

      const setText = (id: string, t: string) => { const el = document.getElementById(id); if (el) el.textContent = t; };
      const play = (i: number) => {
        cur = i;
        if (timer) { clearInterval(timer); timer = null; }
        const frames = rows[i]; if (!frames) return;
        let idx = 0; drawFrame(mctx, main, img, frames[0], 0.92);
        if (frames.length > 1) timer = window.setInterval(() => { idx = (idx + 1) % frames.length; drawFrame(mctx, main, img, frames[idx], 0.92); }, 150);
        const name = NAMES[i] ?? `State ${i + 1}`;
        setText("viewerState", name);
        setText("viewerFrames", frames.length + (frames.length === 1 ? " frame" : " frames"));
        setText("viewerCaption", CAPTIONS[name] ?? "A custom animation in this pack.");
        grid.querySelectorAll("[data-row]").forEach((el) => {
          const on = Number((el as HTMLElement).dataset.row) === i;
          el.classList.toggle("ring-2", on);
          el.classList.toggle("ring-brand-400", on);
        });
      };

      img.onload = () => {
        const r = sliceRows(img); if (!r || !r.length) return;
        rows = r;
        setText("stateCount", String(rows.length));
        const totalFrames = rows.reduce((a, f) => a + f.length, 0);
        setStat("animated", Math.round((totalFrames / 72) * 100), totalFrames);
        setStat("states", Math.round((rows.length / 9) * 100), rows.length);
        grid.innerHTML = "";
        rows.forEach((frames, i) => {
          const name = NAMES[i] ?? `State ${i + 1}`;
          const cardEl = document.createElement("button");
          cardEl.type = "button";
          cardEl.dataset.row = String(i);
          cardEl.className = "card group flex items-center gap-4 p-4 text-left transition hover:-translate-y-0.5 ring-brand-400";
          cardEl.innerHTML = `
            <div class="min-w-0 flex-1">
              <div class="font-display text-base font-semibold text-ink">${name}</div>
              <div class="font-pixel text-[11px] tracking-wide text-faint">Row ${i} · ${frames.length} ${frames.length === 1 ? "frame" : "frames"}</div>
            </div>
            <div class="grid h-16 w-16 shrink-0 place-items-center rounded-xl border border-line sprite-checker">
              <canvas width="120" height="120" class="h-full w-full"></canvas>
            </div>`;
          cardEl.addEventListener("click", () => play(i));
          grid.appendChild(cardEl);
          // animate this state's thumbnail continuously
          const tc = cardEl.querySelector("canvas") as HTMLCanvasElement;
          const tctx = tc.getContext("2d")!; tctx.imageSmoothingEnabled = false;
          let ti = 0; drawFrame(tctx, tc, img, frames[0], 0.82);
          if (frames.length > 1) window.setInterval(() => { ti = (ti + 1) % frames.length; drawFrame(tctx, tc, img, frames[ti], 0.82); }, 150);
        });
        play(0);
      };
      img.src = main.dataset.sheet!;
      main.addEventListener("click", () => { if (rows.length) play((cur + 1) % rows.length); });
    }

    // Share: native share where available, else copy the link.
    const shareBtn = document.getElementById("shareBtn");
    shareBtn?.addEventListener("click", async () => {
      const url = location.href;
      const label = document.getElementById("shareLabel");
      try {
        if ((navigator as any).share) { await (navigator as any).share({ title: document.title, url }); return; }
        await navigator.clipboard.writeText(url);
        if (label) { label.textContent = "Copied!"; window.setTimeout(() => { label.textContent = "Share"; }, 1500); }
      } catch {}
    });

    // Shuffle + keyboard navigation (←/→ prev/next, Space shuffle).
    const shuffleBtn = document.getElementById("shuffleBtn") as HTMLButtonElement | null;
    async function shuffle() {
      if (shuffleBtn) { shuffleBtn.disabled = true; shuffleBtn.classList.add("opacity-60"); }
      try { const d: any = await (await fetch("/api/random-pet.json")).json(); if (d?.slug) location.href = "/pet/" + d.slug; } catch {}
      if (shuffleBtn) { shuffleBtn.disabled = false; shuffleBtn.classList.remove("opacity-60"); }
    }
    shuffleBtn?.addEventListener("click", shuffle);
    document.addEventListener("keydown", (e) => {
      const t = e.target as HTMLElement | null;
      if (t && (t.tagName === "INPUT" || t.tagName === "TEXTAREA")) return;
      if (e.key === "ArrowLeft") (document.getElementById("navPrev") as HTMLAnchorElement | null)?.click();
      else if (e.key === "ArrowRight") (document.getElementById("navNext") as HTMLAnchorElement | null)?.click();
      else if (e.key === " ") { e.preventDefault(); shuffle(); }
    });

    // Similar pets: same category, a few random picks (animate on hover).
    function setupSimThumb(cv: HTMLCanvasElement) {
      const ctx = cv.getContext("2d")!; ctx.imageSmoothingEnabled = false;
      const im = new Image(); let fr: Frame[] = []; let i = 0; let tm: number | null = null;
      const dr = (f: Frame) => { ctx.clearRect(0, 0, cv.width, cv.height); const s = Math.min(cv.width / f.w, cv.height / f.h) * 0.72, dw = f.w * s, dh = f.h * s; ctx.drawImage(im, f.x, f.y, f.w, f.h, (cv.width - dw) / 2, (cv.height - dh) / 2, dw, dh); };
      const pl = () => { if (tm || fr.length < 2) return; tm = window.setInterval(() => { i = (i + 1) % fr.length; dr(fr[i]); }, 150); };
      const sp = () => { if (tm) { clearInterval(tm); tm = null; } i = 0; if (fr[0]) dr(fr[0]); };
      im.onload = () => { const r = sliceRows(im); if (!r || !r.length) return; fr = r.flat(); dr(fr[0]); };
      im.src = cv.dataset.sheet!;
      const host = cv.closest("a")!; host.addEventListener("mouseenter", pl); host.addEventListener("mouseleave", sp);
    }
    const simWrap = document.getElementById("similarWrap");
    if (simWrap) {
      const curSlug = simWrap.dataset.slug, curKind = simWrap.dataset.kind;
      const escS = (s: string) => String(s).replace(/[&<>"']/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]!));
      fetch("/api/pets.json").then((r) => r.json()).then((d: any) => {
        let pool = (d.pets || []).filter((p: any) => p.slug !== curSlug && p.kind === curKind);
        for (let k = pool.length - 1; k > 0; k--) { const j = Math.floor(Math.random() * (k + 1)); [pool[k], pool[j]] = [pool[j], pool[k]]; }
        pool = pool.slice(0, 5);
        const g = document.getElementById("similarGrid"); if (!g) return;
        if (!pool.length) { simWrap.classList.add("hidden"); return; }
        g.innerHTML = pool.map((p: any) => `
          <a href="/pet/${escS(p.slug)}" class="card group flex flex-col overflow-hidden p-0 transition hover:-translate-y-1">
            <div class="m-2 mb-0 grid aspect-square place-items-center rounded-2xl border border-line sprite-checker p-2"><canvas class="sim-thumb h-full w-full" width="150" height="150" data-sheet="/api/sprite/${escS(p.slug)}"></canvas></div>
            <div class="truncate px-3 py-2 text-center font-display text-sm font-semibold text-ink">${escS(p.name)}</div>
          </a>`).join("");
        g.querySelectorAll<HTMLCanvasElement>(".sim-thumb").forEach(setupSimThumb);
      }).catch(() => {});
    }
  </script>
</Base>

---
import Base from "../layouts/Base.astro";
import Icon from "../components/Icon.astro";
import Hero from "../components/Hero.astro";
---
<Base title="Leaderboard · AgentPet" description="The most liked pets and the community's biggest fans." active="leaderboard">
  <Hero
    eyebrow="Community favourites"
    icon="star"
    title="The"
    accent="leaderboard"
    lead="The most liked pixel companions, and the fans who show them the most love. Sign in and tap the heart to move the rankings."
  />

  <!-- top raised companions -->
  <section class="px-4 pt-6">
    <div class="mx-auto max-w-6xl">
      <div class="card p-6 sm:p-7">
        <div class="flex items-center gap-2">
          <span class="grid h-9 w-9 place-items-center rounded-xl bg-amber-50 text-amber-600"><Icon name="paw" class="h-5 w-5" /></span>
          <h2 class="font-display text-xl font-bold text-ink">Top companions</h2>
          <span class="rounded-full bg-amber-100 px-2 py-0.5 text-[11px] font-bold text-amber-700">by XP</span>
        </div>
        <p class="mt-1 text-sm text-muted">The highest-level pets across the community, raised by feeding real agent work.</p>
        <div id="lb-companions" class="mt-5 grid gap-3 sm:grid-cols-2 lg:grid-cols-3"></div>
        <div id="lb-companions-empty" class="hidden py-10 text-center text-muted">No raised companions yet. <a href="/profile" class="font-semibold text-brand-600 hover:text-brand-700">Connect the app</a> to be the first!</div>
      </div>
    </div>
  </section>

  <section class="px-4 pt-6">
    <div class="mx-auto grid max-w-6xl gap-6 lg:grid-cols-[1.4fr_1fr]">
      <!-- most liked pets -->
      <div class="card p-6 sm:p-7">
        <div class="flex items-center gap-2">
          <span class="grid h-9 w-9 place-items-center rounded-xl bg-accent-500/15 text-accent-600"><Icon name="heart" class="h-5 w-5" /></span>
          <h2 class="font-display text-xl font-bold text-ink">Most liked pets</h2>
        </div>
        <div id="lb-pets" class="mt-5 space-y-2"></div>
        <div id="lb-pets-empty" class="hidden py-10 text-center text-muted">No likes yet. Be the first to tap a heart!</div>
      </div>

      <div class="space-y-6">
        <!-- top creators -->
        <div class="card p-6 sm:p-7">
          <div class="flex items-center gap-2">
            <span class="grid h-9 w-9 place-items-center rounded-xl bg-emerald-50 text-emerald-600"><Icon name="wand" class="h-5 w-5" /></span>
            <h2 class="font-display text-xl font-bold text-ink">Top creators</h2>
          </div>
          <div id="lb-creators" class="mt-5 space-y-2"></div>
          <div id="lb-creators-empty" class="hidden py-8 text-center text-sm text-muted">No creators yet. <a href="/submit" class="font-semibold text-brand-600 hover:text-brand-700">Submit a pet</a> to be the first!</div>
        </div>

        <!-- top fans -->
        <div class="card p-6 sm:p-7">
          <div class="flex items-center gap-2">
            <span class="grid h-9 w-9 place-items-center rounded-xl bg-brand-50 text-brand-600"><Icon name="users" class="h-5 w-5" /></span>
            <h2 class="font-display text-xl font-bold text-ink">Top fans</h2>
          </div>
          <div id="lb-fans" class="mt-5 space-y-2"></div>
          <div id="lb-fans-empty" class="hidden py-10 text-center text-muted">No fans yet. Sign in and start liking!</div>
        </div>
      </div>
    </div>
  </section>

  <script>
    type Frame = { x: number; y: number; w: number; h: number };
    function seg(a: boolean[]) { const r: [number, number][] = []; let s: number | null = null; for (let i = 0; i < a.length; i++) { if (a[i] && s === null) s = i; else if (!a[i] && s !== null) { r.push([s, i]); s = null; } } if (s !== null) r.push([s, a.length]); return r; }
    function firstFrame(img: HTMLImageElement): Frame | null {
      const w = img.naturalWidth, h = img.naturalHeight, TH = 16;
      const off = document.createElement("canvas"); off.width = w; off.height = h;
      const o = off.getContext("2d")!; o.drawImage(img, 0, 0);
      let px: Uint8ClampedArray; try { px = o.getImageData(0, 0, w, h).data; } catch { return null; }
      const rowHas: boolean[] = new Array(h).fill(false);
      for (let y = 0; y < h; y++) { const b = y * w * 4; for (let x = 0; x < w; x++) if (px[b + x * 4 + 3] > TH) { rowHas[y] = true; break; } }
      const rows = seg(rowHas); if (!rows.length) return null;
      const [y0, y1] = rows[0];
      const colHas: boolean[] = new Array(w).fill(false);
      for (let x = 0; x < w; x++) for (let y = y0; y < y1; y++) if (px[(y * w + x) * 4 + 3] > TH) { colHas[x] = true; break; }
      const cols = seg(colHas); if (!cols.length) return null;
      const [x0, x1] = cols[0];
      return { x: x0, y: y0, w: x1 - x0, h: y1 - y0 };
    }
    function drawThumb(cv: HTMLCanvasElement, slug: string) {
      const ctx = cv.getContext("2d")!; ctx.imageSmoothingEnabled = false;
      const img = new Image();
      img.onload = () => { const f = firstFrame(img); if (!f) return; const s = Math.min(cv.width / f.w, cv.height / f.h) * 0.9, dw = f.w * s, dh = f.h * s; ctx.clearRect(0, 0, cv.width, cv.height); ctx.drawImage(img, f.x, f.y, f.w, f.h, (cv.width - dw) / 2, (cv.height - dh) / 2, dw, dh); cv.parentElement?.classList.remove("ap-skel"); };
      img.src = "/api/sprite/" + slug;
    }
    const esc = (s: string) => String(s).replace(/[^a-zA-Z0-9 ._-]/g, "");

    (async () => {
      const skelRow = `<div class="flex items-center gap-3 rounded-2xl border border-line bg-white px-3 py-2"><span class="h-6 w-6 shrink-0 rounded-full ap-skel"></span><span class="h-9 w-9 shrink-0 rounded-full ap-skel"></span><span class="h-4 flex-1 rounded ap-skel"></span></div>`;
      ["lb-pets", "lb-fans", "lb-creators"].forEach((id) => { const el = document.getElementById(id); if (el) el.innerHTML = skelRow.repeat(5); });
      const [lb, pj] = await Promise.all([
        fetch("/api/leaderboard.json").then((r) => r.json()).catch(() => ({ pets: [], fans: [] })),
        fetch("/api/pets.json").then((r) => r.json()).catch(() => ({ pets: [] })),
      ]);
      const names: Record<string, string> = {};
      for (const p of pj.pets || []) names[p.slug] = p.name;

      const petsBox = document.getElementById("lb-pets")!;
      const pets = lb.pets || [];
      document.getElementById("lb-pets-empty")!.classList.toggle("hidden", pets.length > 0);
      petsBox.innerHTML = pets.map((p: any, i: number) => `
        <a href="/pet/${p.slug}" class="flex items-center gap-3 rounded-2xl border border-line bg-white px-3 py-2 transition hover:border-brand-300 hover:bg-brand-50/40">
          <span class="w-6 shrink-0 text-center font-display text-sm font-bold ${i < 3 ? "text-accent-600" : "text-faint"}">${i + 1}</span>
          <span class="grid h-12 w-12 shrink-0 place-items-center rounded-xl border border-line sprite-checker ap-skel"><canvas class="lb-thumb h-10 w-10" width="80" height="80" data-slug="${p.slug}"></canvas></span>
          <span class="min-w-0 flex-1 truncate font-display font-semibold text-ink">${esc(names[p.slug] || p.slug)}</span>
          <span class="inline-flex shrink-0 items-center gap-1 text-sm font-semibold text-muted"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4 text-accent-500"><path d="M20.8 6.6a5 5 0 0 0-7.1 0L12 8.3l-1.7-1.7a5 5 0 1 0-7.1 7.1l1.7 1.7L12 22l7.1-7.1 1.7-1.7a5 5 0 0 0 0-7.1z"/></svg>${p.likes}</span>
        </a>`).join("");
      petsBox.querySelectorAll<HTMLCanvasElement>("canvas.lb-thumb").forEach((cv) => drawThumb(cv, cv.dataset.slug!));

      const creatorsBox = document.getElementById("lb-creators")!;
      const creators = lb.creators || [];
      document.getElementById("lb-creators-empty")!.classList.toggle("hidden", creators.length > 0);
      creatorsBox.innerHTML = creators.map((u: any, i: number) => {
        const login = esc(u.login);
        const avatar = u.avatar ? `<img src="${u.avatar}" alt="" class="h-9 w-9 shrink-0 rounded-full" />` : `<span class="grid h-9 w-9 shrink-0 place-items-center rounded-full bg-emerald-50 text-emerald-600 font-display font-bold">${login.charAt(0).toUpperCase()}</span>`;
        return `
        <a href="https://github.com/${login}" target="_blank" rel="noopener" class="flex items-center gap-3 rounded-2xl border border-line bg-white px-3 py-2 transition hover:border-brand-300 hover:bg-brand-50/40">
          <span class="w-6 shrink-0 text-center font-display text-sm font-bold ${i < 3 ? "text-emerald-600" : "text-faint"}">${i + 1}</span>
          ${avatar}
          <span class="min-w-0 flex-1 truncate font-display font-semibold text-ink">${login}</span>
          <span class="shrink-0 text-sm font-medium text-muted">${u.count} pet${u.count === 1 ? "" : "s"}</span>
        </a>`;
      }).join("");

      const fansBox = document.getElementById("lb-fans")!;
      const fans = lb.fans || [];
      document.getElementById("lb-fans-empty")!.classList.toggle("hidden", fans.length > 0);
      fansBox.innerHTML = fans.map((u: any, i: number) => {
        const login = esc(u.login);
        return `
        <a href="https://github.com/${login}" target="_blank" rel="noopener" class="flex items-center gap-3 rounded-2xl border border-line bg-white px-3 py-2 transition hover:border-brand-300 hover:bg-brand-50/40">
          <span class="w-6 shrink-0 text-center font-display text-sm font-bold ${i < 3 ? "text-accent-600" : "text-faint"}">${i + 1}</span>
          <img src="${u.avatar}" alt="" class="h-9 w-9 shrink-0 rounded-full" />
          <span class="min-w-0 flex-1 truncate font-display font-semibold text-ink">${login}</span>
          <span class="shrink-0 text-sm font-medium text-muted">${u.count} like${u.count === 1 ? "" : "s"}</span>
        </a>`;
      }).join("");

      // Top raised companions (care leaderboard).
      const STAGES2: [number, string, string][] = [[35, "Legend", "#f59e0b"], [20, "Hero", "#a855f7"], [10, "Scout", "#3b82f6"], [5, "Companion", "#14b8a6"], [0, "Hatchling", "#22c55e"]];
      const levelFor = (xp: number) => { let n = 1; while (60 * (n + 1) * n <= xp) n++; return n; };
      const stageFor = (lv: number) => { for (const [m, s, c] of STAGES2) if (lv >= m) return [s, c] as [string, string]; return ["Hatchling", "#22c55e"] as [string, string]; };
      const tokenLabel = (n: number) => n >= 1e6 ? (n / 1e6).toFixed(1) + "M" : n >= 1e3 ? Math.round(n / 1e3) + "k" : String(n);
      const cBox = document.getElementById("lb-companions");
      if (cBox) {
        const cl = await fetch("/api/care/leaderboard.json").then((r) => r.json()).catch(() => ({ pets: [] }));
        const cpets = cl.pets || [];
        document.getElementById("lb-companions-empty")!.classList.toggle("hidden", cpets.length > 0);
        cBox.innerHTML = cpets.map((p: any, i: number) => {
          const lv = levelFor(p.xp);
          const [stage, color] = stageFor(lv);
          const owner = p.owner ? esc(p.owner) : "";
          const thumb = p.thumb
            ? `<img src="${p.thumb}" alt="" class="pixel-art h-10 w-10 object-contain" />`
            : `<span class="font-display text-sm font-bold" style="color:${color}">${(p.name || "?").charAt(0).toUpperCase()}</span>`;
          const ownerTag = owner
            ? `<a href="https://github.com/${owner}" target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-xs text-muted hover:text-brand-700">${p.ownerAvatar ? `<img src="${p.ownerAvatar}" class="h-4 w-4 rounded-full" alt="" />` : ""}${owner}</a>`
            : `<span class="text-xs text-faint">someone</span>`;
          return `
            <div class="flex items-center gap-3 rounded-2xl border border-line bg-white px-3 py-2.5">
              <span class="w-5 shrink-0 text-center font-display text-sm font-bold ${i < 3 ? "text-amber-600" : "text-faint"}">${i + 1}</span>
              <span class="grid h-11 w-11 shrink-0 place-items-center rounded-xl" style="background:${color}14">${thumb}</span>
              <span class="min-w-0 flex-1">
                <span class="block truncate font-display font-semibold text-ink">${esc(p.name)}</span>
                ${ownerTag}
              </span>
              <span class="shrink-0 text-right">
                <span class="block font-display text-base font-bold" style="color:${color}">Lv ${lv}</span>
                <span class="block text-[11px] text-faint">${tokenLabel(p.tokens)} tok</span>
              </span>
            </div>`;
        }).join("");
      }
    })();
  </script>
</Base>

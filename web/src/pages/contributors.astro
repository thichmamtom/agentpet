---
import Base from "../layouts/Base.astro";
import Icon from "../components/Icon.astro";
import Hero from "../components/Hero.astro";

export const prerender = false;

const REPO = "ntd4996/agentpet";

// Founders are curated (not necessarily top code committers) and featured first.
const FOUNDERS = [
  { login: "ntd4996", name: "Nguyễn Thành Đạt", role: "Founder & maintainer", avatar_url: "https://avatars.githubusercontent.com/u/46896275?v=4", html_url: "https://github.com/ntd4996" },
  { login: "hoangphison", name: "Sơn Hoàng", role: "Cofounder", avatar_url: "https://avatars.githubusercontent.com/u/9270621?v=4", html_url: "https://github.com/hoangphison" },
];
const FOUNDER_LOGINS = new Set(FOUNDERS.map((f) => f.login));

// Baked snapshot, used if the GitHub API is unreachable or rate-limited.
const FALLBACK = [
  { login: "3xhvy", avatar_url: "https://avatars.githubusercontent.com/u/127609002?v=4", html_url: "https://github.com/3xhvy" },
  { login: "tranhuuhuy297", avatar_url: "https://avatars.githubusercontent.com/u/46334604?v=4", html_url: "https://github.com/tranhuuhuy297" },
  { login: "heo001997", avatar_url: "https://avatars.githubusercontent.com/u/20258751?v=4", html_url: "https://github.com/heo001997" },
  { login: "minhat-dg", avatar_url: "https://avatars.githubusercontent.com/u/70907443?v=4", html_url: "https://github.com/minhat-dg" },
];

const NAMES: Record<string, string> = { "3xhvy": "Hồ Hoàng Huy" };
const ROLES: Record<string, string> = { "3xhvy": "Multi-agent bubble" };

let contributors: any[] = FALLBACK;
try {
  const res = await fetch(`https://api.github.com/repos/${REPO}/contributors?per_page=100`, {
    headers: { "User-Agent": "agentpet-site", Accept: "application/vnd.github+json" },
  });
  if (res.ok) {
    const data: any = await res.json();
    if (Array.isArray(data) && data.length) contributors = data.filter((c: any) => c.type !== "Bot");
  }
} catch {}
contributors = contributors.filter((c) => !FOUNDER_LOGINS.has(c.login));

const name = (login: string) => NAMES[login] || login;
const role = (login: string) => ROLES[login] || "Contributor";
---
<Base title="Contributors · AgentPet" description="The team and community behind AgentPet." active="contributors">
  <Hero
    eyebrow="Team & community"
    icon="heart"
    title="Built by"
    accent="great people"
    lead="AgentPet is open source and shaped by everyone who ships code, art, and ideas. Meet the people behind the pet."
  >
    <a href="https://github.com/ntd4996/agentpet" target="_blank" rel="noopener" class="btn-primary !px-6 !py-3"><Icon name="grid" class="h-5 w-5" /> View on GitHub</a>
    <a href="https://github.com/ntd4996/agentpet/issues" target="_blank" rel="noopener" class="btn-ghost !px-6 !py-3"><Icon name="sparkles" class="h-5 w-5" /> Find an issue to fix</a>
  </Hero>

  <!-- Founders -->
  <section class="px-4 pt-10">
    <div class="mx-auto max-w-3xl">
      <p class="text-center font-pixel text-[11px] uppercase tracking-[0.2em] text-brand-500">Founders</p>
      <div class="mx-auto mt-6 grid max-w-2xl gap-6 sm:grid-cols-2">
        {FOUNDERS.map((f) => (
          <a href={f.html_url} target="_blank" rel="noopener"
             class="group relative overflow-hidden rounded-3xl border border-line bg-white p-8 text-center shadow-soft transition hover:-translate-y-1 hover:border-brand-300 hover:shadow-card">
            <div class="pointer-events-none absolute inset-x-0 top-0 h-24 bg-gradient-to-b from-brand-50 to-transparent"></div>
            <div class="relative mx-auto w-fit rounded-full bg-gradient-to-br from-brand-400 via-brand-500 to-accent-500 p-[3px] shadow-soft transition group-hover:scale-105">
              <img src={f.avatar_url} alt={f.name} width="104" height="104"
                   class="h-26 w-26 rounded-full border-2 border-white bg-white object-cover" style="height:104px;width:104px" />
            </div>
            <div class="relative mt-5 font-display text-xl font-bold text-ink">{f.name}</div>
            <div class="relative text-sm text-muted">@{f.login}</div>
            <span class="relative mt-4 inline-flex items-center gap-1.5 rounded-full bg-gradient-to-b from-brand-500 to-brand-600 px-4 py-1.5 text-xs font-bold uppercase tracking-wide text-white shadow-soft">
              <Icon name="star" class="h-3.5 w-3.5" />{f.role}
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Contributors -->
  <section class="px-4 pt-14 pb-20">
    <div class="mx-auto max-w-5xl">
      <p class="text-center font-pixel text-[11px] uppercase tracking-[0.2em] text-brand-500">Contributors</p>
      <h2 class="mt-2 text-center font-display text-2xl font-bold text-ink">Everyone who shipped code</h2>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {contributors.map((c) => (
          <a href={c.html_url} target="_blank" rel="noopener"
             class="group flex items-center gap-4 rounded-2xl border border-line bg-white p-4 shadow-soft transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-card">
            <div class="rounded-2xl bg-gradient-to-br from-brand-200 to-accent-400 p-[2px]">
              <img src={c.avatar_url} alt={name(c.login)} width="56" height="56" loading="lazy"
                   class="h-14 w-14 shrink-0 rounded-2xl border-2 border-white bg-white object-cover" />
            </div>
            <div class="min-w-0">
              <div class="truncate font-display font-semibold text-ink">{name(c.login)}</div>
              <div class="truncate text-sm text-muted">@{c.login}</div>
              <span class="mt-1.5 inline-flex items-center gap-1 rounded-full bg-brand-50 px-2.5 py-0.5 text-xs font-semibold text-brand-700">{role(c.login)}</span>
            </div>
          </a>
        ))}
      </div>
      <p class="mx-auto mt-12 max-w-2xl text-center text-muted">
        Want your face here? AgentPet is open source , send a pull request on
        <a class="font-semibold text-brand-700 hover:underline" href="https://github.com/ntd4996/agentpet">GitHub</a>.
      </p>
    </div>
  </section>
</Base>

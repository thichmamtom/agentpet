---
import Base from "../layouts/Base.astro";
import Icon from "../components/Icon.astro";

export const prerender = false;

const REPO = "ntd4996/agentpet";

// Founders are listed first; everyone is shown with the same card.
const FOUNDERS = [
  { login: "ntd4996", name: "Nguyễn Thành Đạt", role: "Founder & maintainer", avatar_url: "https://avatars.githubusercontent.com/u/46896275?v=4", html_url: "https://github.com/ntd4996" },
  { login: "hoangphison", name: "Sơn Hoàng", role: "Cofounder", avatar_url: "https://avatars.githubusercontent.com/u/9270621?v=4", html_url: "https://github.com/hoangphison" },
];
const FOUNDER_LOGINS = new Set(FOUNDERS.map((f) => f.login));

// Always-include set: merged contributors that GitHub's cached contributor
// API can lag behind by hours, so we union them in to show credit right away.
const KNOWN = [
  { login: "3xhvy", avatar_url: "https://avatars.githubusercontent.com/u/127609002?v=4", html_url: "https://github.com/3xhvy" },
  { login: "aiexkwan", avatar_url: "https://avatars.githubusercontent.com/u/203569546?v=4", html_url: "https://github.com/aiexkwan" },
  { login: "23092003e", avatar_url: "https://avatars.githubusercontent.com/u/114332653?v=4", html_url: "https://github.com/23092003e" },
  { login: "tranhuuhuy297", avatar_url: "https://avatars.githubusercontent.com/u/46334604?v=4", html_url: "https://github.com/tranhuuhuy297" },
  { login: "heo001997", avatar_url: "https://avatars.githubusercontent.com/u/20258751?v=4", html_url: "https://github.com/heo001997" },
  { login: "minhat-dg", avatar_url: "https://avatars.githubusercontent.com/u/70907443?v=4", html_url: "https://github.com/minhat-dg" },
];

const NAMES: Record<string, string> = { "3xhvy": "Hồ Hoàng Huy", "23092003e": "Mạnh Hoàng" };
const ROLES: Record<string, string> = {
  "3xhvy": "Multi-agent bubble",
  "aiexkwan": "Memory & performance",
  "23092003e": "Windows hooks",
};

let rest: any[] = [...KNOWN];
try {
  const res = await fetch(`https://api.github.com/repos/${REPO}/contributors?per_page=100`, {
    headers: { "User-Agent": "agentpet-site", Accept: "application/vnd.github+json" },
  });
  if (res.ok) {
    const data: any = await res.json();
    if (Array.isArray(data) && data.length) {
      // Union the API list with KNOWN (API order first), dedup by login.
      const seen = new Set<string>();
      rest = [];
      for (const c of [...data.filter((c: any) => c.type !== "Bot"), ...KNOWN]) {
        if (seen.has(c.login)) continue;
        seen.add(c.login);
        rest.push(c);
      }
    }
  }
} catch {}
rest = rest.filter((c) => !FOUNDER_LOGINS.has(c.login));

// Everyone in one honour roll, founders first, all rendered the same way.
const people = [
  ...FOUNDERS,
  ...rest.map((c: any) => ({
    login: c.login,
    name: NAMES[c.login] || c.login,
    role: ROLES[c.login] || "Contributor",
    avatar_url: c.avatar_url,
    html_url: c.html_url,
  })),
];
---
<Base title="Contributors · AgentPet" description="The team and community behind AgentPet." active="contributors">
  <!-- Honour-roll header (extra top room so the floating nav never overlaps it) -->
  <section class="px-4 pt-20 pb-4 text-center sm:pt-24">
    <span class="chip"><Icon name="star" class="h-4 w-4" /> Hall of fame</span>
    <h1 class="mx-auto mt-5 max-w-3xl font-display text-4xl font-bold leading-[1.1] text-ink sm:text-5xl">
      The people who build <span class="text-brand-600">AgentPet</span>
    </h1>
    <p class="mx-auto mt-4 max-w-xl text-lg text-[#3f4a6b]">
      Open source, made with love by a small team and a growing community. Thank you to everyone who ships code, art, and ideas.
    </p>
    <div class="mt-7 flex flex-wrap justify-center gap-3">
      <a href="https://github.com/ntd4996/agentpet" target="_blank" rel="noopener" class="btn-primary !px-6 !py-3"><Icon name="grid" class="h-5 w-5" /> View on GitHub</a>
      <a href="https://github.com/ntd4996/agentpet/issues" target="_blank" rel="noopener" class="btn-ghost !px-6 !py-3"><Icon name="sparkles" class="h-5 w-5" /> Find an issue to fix</a>
    </div>
  </section>

  <!-- One honour roll: everyone shown with the same card -->
  <section class="px-4 pt-10 pb-20">
    <div class="mx-auto grid max-w-5xl gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {people.map((p) => (
        <a href={p.html_url} target="_blank" rel="noopener"
           class="group flex items-center gap-4 rounded-2xl border border-line bg-white p-4 shadow-soft transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-card">
          <div class="shrink-0 rounded-2xl bg-gradient-to-br from-brand-300 to-accent-400 p-[2px]">
            <img src={p.avatar_url} alt={p.name} width="56" height="56" loading="lazy"
                 class="h-14 w-14 rounded-2xl border-2 border-white bg-white object-cover" />
          </div>
          <div class="min-w-0">
            <div class="truncate font-semibold text-ink">{p.name}</div>
            <div class="truncate text-sm text-muted">@{p.login}</div>
            <span class="mt-1.5 inline-flex items-center gap-1 rounded-full bg-brand-50 px-2.5 py-0.5 text-xs font-semibold text-brand-700">{p.role}</span>
          </div>
        </a>
      ))}
    </div>
    <p class="mx-auto mt-12 max-w-2xl text-center text-muted">
      {people.length} people and counting. Want your face here? AgentPet is open source , send a pull request on
      <a class="font-semibold text-brand-700 hover:underline" href="https://github.com/ntd4996/agentpet">GitHub</a>.
    </p>
  </section>
</Base>

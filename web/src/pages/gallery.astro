---
import Base from "../layouts/Base.astro";
import Icon from "../components/Icon.astro";
import Hero from "../components/Hero.astro";
const KINDS = ["all", "creature", "character", "critter", "spirit", "object"];
---
<Base title="Pet gallery — AgentPet" description="Browse thousands of pixel companions for your AI coding agents." active="gallery">
  <Hero
    eyebrow="Pet gallery"
    icon="grid"
    title="Adopt your"
    accent="pixel pal"
    lead="Hundreds of community companions are ready to roam your desktop. Hover a pet to watch it move, click to meet it."
  >
    <a href="/install" class="btn-primary !px-6 !py-3"><Icon name="download" class="h-5 w-5" /> Get the app</a>
    <a href="/make" class="btn-ghost !px-6 !py-3"><Icon name="wand" class="h-5 w-5" /> Make your own</a>
  </Hero>

  <section class="px-4 pt-8">
    <div class="mx-auto max-w-6xl">
      <div class="card flex flex-col gap-4 p-4 sm:flex-row sm:items-center">
        <label class="relative flex flex-1 items-center">
          <Icon name="search" class="pointer-events-none absolute left-4 h-5 w-5 text-faint" />
          <input id="q" type="search" placeholder="Search pets by name…" class="w-full rounded-full border border-line bg-white py-3 pl-12 pr-4 text-ink outline-none focus:border-brand-300" />
        </label>
        <div id="chips" class="flex flex-wrap gap-2">
          {KINDS.map((k) => (
            <button data-kind={k} class={`chip ${k === "all" ? "chip-active" : ""} capitalize`}>{k}</button>
          ))}
        </div>
      </div>

      <div class="mt-4 px-1 text-sm text-muted"><span id="count">Loading…</span></div>

      <div id="grid" class="mt-4 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4"></div>
      <div id="empty" class="hidden py-16 text-center text-muted">No pets match that search.</div>

      <div class="mt-8 flex justify-center pb-4">
        <button id="more" class="btn-ghost !px-6 !py-3" hidden><Icon name="sparkles" class="h-4 w-4" /> Load more</button>
      </div>
    </div>
  </section>

  <script>
    type Frame = { x: number; y: number; w: number; h: number };
    function fnv(s: string): number { let x = 2166136261; for (let i = 0; i < s.length; i++) { x ^= s.charCodeAt(i); x = Math.imul(x, 16777619) >>> 0; } return x >>> 0; }
    const KINDS = ["creature", "character", "critter", "spirit", "object"];
    const kindOf = (slug: string) => KINDS[(fnv(slug) >>> 3) % KINDS.length];
    const TRAITS = ["focused", "mischievous", "sleepy", "cheerful", "brave", "shy", "curious", "chaotic", "loyal", "zen", "sassy", "dreamy"];
    // Deterministic placeholder stats (per slug), same scheme as the home page,
    // until the community backend (likes / downloads) is wired up.
    const statOf = (slug: string, k: string, mod: number, base: number) => (fnv(slug + k) % mod) + base;

    function seg(arr: boolean[]) { const r: [number, number][] = []; let s: number | null = null; for (let i = 0; i < arr.length; i++) { if (arr[i] && s === null) s = i; else if (!arr[i] && s !== null) { r.push([s, i]); s = null; } } if (s !== null) r.push([s, arr.length]); return r; }
    function sliceRows(img: HTMLImageElement) {
      const w = img.naturalWidth, h = img.naturalHeight, TH = 16;
      const off = document.createElement("canvas"); off.width = w; off.height = h;
      const o = off.getContext("2d")!; o.drawImage(img, 0, 0);
      let px: Uint8ClampedArray; try { px = o.getImageData(0, 0, w, h).data; } catch { return null; }
      const rowHas: boolean[] = new Array(h).fill(false);
      for (let y = 0; y < h; y++) { const b = y * w * 4; for (let x = 0; x < w; x++) if (px[b + x * 4 + 3] > TH) { rowHas[y] = true; break; } }
      const rows: Frame[][] = [];
      for (const [y0, y1] of seg(rowHas)) {
        const colHas: boolean[] = new Array(w).fill(false);
        for (let x = 0; x < w; x++) for (let y = y0; y < y1; y++) if (px[(y * w + x) * 4 + 3] > TH) { colHas[x] = true; break; }
        const fr = seg(colHas).map(([x0, x1]) => ({ x: x0, y: y0, w: x1 - x0, h: y1 - y0 }));
        if (fr.length) rows.push(fr);
      }
      return rows;
    }
    function setupCanvas(cv: HTMLCanvasElement) {
      const ctx = cv.getContext("2d")!; ctx.imageSmoothingEnabled = false;
      const img = new Image(); let frames: Frame[] = []; let idx = 0; let timer: number | null = null;
      const draw = (f: Frame) => { ctx.clearRect(0, 0, cv.width, cv.height); const s = Math.min(cv.width / f.w, cv.height / f.h) * 0.62, dw = f.w * s, dh = f.h * s; ctx.drawImage(img, f.x, f.y, f.w, f.h, (cv.width - dw) / 2, (cv.height - dh) / 2, dw, dh); };
      const play = () => { if (timer || frames.length < 2) return; timer = window.setInterval(() => { idx = (idx + 1) % frames.length; draw(frames[idx]); }, 150); };
      const stop = () => { if (timer) { clearInterval(timer); timer = null; } idx = 0; if (frames[0]) draw(frames[0]); };
      img.onload = () => { const rows = sliceRows(img); if (!rows || !rows.length) return; const st = cv.closest("a")?.querySelector<HTMLElement>(".states"); if (st) st.textContent = rows.length + (rows.length === 1 ? " state" : " states"); frames = rows.flat(); draw(frames[0]); };
      img.src = cv.dataset.sheet!;
      const host = cv.closest("a")!; host.addEventListener("mouseenter", play); host.addEventListener("mouseleave", stop);
    }
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) if (e.isIntersecting) { const cv = e.target as HTMLCanvasElement; io.unobserve(cv); setupCanvas(cv); }
    }, { rootMargin: "200px" });

    const grid = document.getElementById("grid")!;
    const moreBtn = document.getElementById("more") as HTMLButtonElement;
    const countEl = document.getElementById("count")!;
    const emptyEl = document.getElementById("empty")!;
    const qEl = document.getElementById("q") as HTMLInputElement;
    let all: { slug: string; name: string; kind: string }[] = [];
    let filtered: typeof all = []; let shown = 0; const BATCH = 50;
    let q = "", kind = "all";

    const esc = (s: string) => s.replace(/[&<>"']/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]!));
    const heartSvg = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5 text-accent-500"><path d="M20.8 6.6a5 5 0 0 0-7.1 0L12 8.3l-1.7-1.7a5 5 0 1 0-7.1 7.1l1.7 1.7L12 22l7.1-7.1 1.7-1.7a5 5 0 0 0 0-7.1z"/></svg>`;
    const dlSvg = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5 text-brand-500"><path d="M12 3v12m0 0l-4-4m4 4l4-4M5 21h14"/></svg>`;
    const monSvg = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5 text-emerald-500"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8m-4-4v4"/></svg>`;
    const starSvg = `<svg viewBox="0 0 24 24" fill="currentColor" class="h-3 w-3"><path d="M12 2.5l2.9 6 6.6.9-4.8 4.6 1.2 6.5L12 18.4 6.1 21l1.2-6.5L2.5 9.4l6.6-.9z"/></svg>`;
    // Mirror the home featured card exactly (NO badge, featured/kind, name+kind,
    // by community, desc fallback, tags, 3-stat footer).
    const card = (p: typeof all[number]) => {
      const f = fnv(p.slug);
      const no = String(100 + (f % 900)).padStart(3, "0");
      const featured = f % 4 === 0;
      const t1 = TRAITS[f % TRAITS.length];
      const t2 = TRAITS[(f >>> 5) % TRAITS.length];
      const tags = Array.from(new Set([t1, t2]));
      const likes = statOf(p.slug, "l", 880, 24);
      const downloads = statOf(p.slug, "d", 7400, 130).toLocaleString();
      const usage = statOf(p.slug, "u", 2400, 12).toLocaleString();
      const head = featured
        ? `<span class="inline-flex items-center gap-1 text-brand-600">${starSvg} FEATURED</span>`
        : `<span class="uppercase">${p.kind}</span>`;
      return `
      <a href="/pet/${p.slug}" class="card group flex flex-col overflow-hidden p-0 transition hover:-translate-y-1">
        <div class="flex items-center justify-between px-4 pt-3 font-pixel text-[11px] tracking-wide text-faint">
          <span>NO. ${no}</span>${head}
        </div>
        <div class="relative mx-4 mt-2 grid aspect-[4/5] place-items-center rounded-2xl border border-line bg-white p-3">
          <canvas class="thumb h-full w-full" width="180" height="220" data-sheet="/api/sprite/${p.slug}"></canvas>
          <span class="states absolute bottom-2 right-2 rounded-full bg-white/90 px-2 py-0.5 font-pixel text-[10px] tracking-wide text-faint shadow-sm"></span>
        </div>
        <div class="px-4 pb-4 pt-3">
          <div class="flex items-baseline justify-between gap-2">
            <span class="truncate font-display text-lg font-semibold text-ink">${esc(p.name)}</span>
            <span class="shrink-0 font-pixel text-[10px] uppercase tracking-wide text-faint">${p.kind}</span>
          </div>
          <div class="text-xs text-faint">by community</div>
          <p class="mt-1 line-clamp-2 min-h-[2rem] text-xs text-muted">A community pixel companion.</p>
          <div class="mt-2 flex flex-wrap gap-1.5">
            ${tags.map((t) => `<span class="rounded-full bg-brand-50 px-2 py-0.5 font-pixel text-[10px] lowercase text-brand-700">#${t}</span>`).join("")}
          </div>
          <div class="mt-3 flex items-center gap-3 border-t border-line pt-2.5 text-xs font-medium text-muted">
            <span class="inline-flex items-center gap-1" title="Likes">${heartSvg}${likes}</span>
            <span class="inline-flex items-center gap-1" title="Downloads">${dlSvg}${downloads}</span>
            <span class="inline-flex items-center gap-1" title="In use now">${monSvg}${usage}</span>
          </div>
        </div>
      </a>`;
    };

    function renderMore() {
      const slice = filtered.slice(shown, shown + BATCH);
      shown += slice.length;
      grid.insertAdjacentHTML("beforeend", slice.map(card).join(""));
      grid.querySelectorAll<HTMLCanvasElement>("canvas.thumb").forEach((cv) => { if (!cv.dataset.obs) { cv.dataset.obs = "1"; io.observe(cv); } });
      moreBtn.hidden = shown >= filtered.length;
    }
    function apply() {
      filtered = all.filter((p) => (kind === "all" || p.kind === kind) && (!q || p.name.toLowerCase().includes(q)));
      shown = 0; grid.innerHTML = "";
      countEl.textContent = `${filtered.length.toLocaleString()} pet${filtered.length === 1 ? "" : "s"}`;
      emptyEl.classList.toggle("hidden", filtered.length > 0);
      renderMore();
    }
    moreBtn.addEventListener("click", renderMore);
    let t: number; qEl.addEventListener("input", () => { clearTimeout(t); t = window.setTimeout(() => { q = qEl.value.trim().toLowerCase(); apply(); }, 180); });
    document.getElementById("chips")!.addEventListener("click", (e) => {
      const b = (e.target as HTMLElement).closest("button"); if (!b) return;
      kind = b.dataset.kind!;
      document.querySelectorAll("#chips button").forEach((x) => x.classList.remove("chip-active"));
      b.classList.add("chip-active"); apply();
    });

    fetch("/api/pets.json").then((r) => r.json()).then((d: any) => {
      all = (d.pets ?? []).map((p: any) => ({ ...p, kind: kindOf(p.slug) }));
      // shuffle once so the gallery isn't always the same order
      for (let i = all.length - 1; i > 0; i--) { const j = Math.floor(Math.random() * (i + 1)); [all[i], all[j]] = [all[j], all[i]]; }
      apply();
    });
  </script>
</Base>

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgentPet",
  "version": "0.1.1",
  "identifier": "online.thenightwatcher.agentpet",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "pet",
        "title": "AgentPet",
        "url": "index.html",
        "width": 260,
        "height": 320,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "focus": false,
        "x": 1200,
        "y": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https://pets.thenightwatcher.online data: ; connect-src 'self' https://pets.thenightwatcher.online ipc: http://ipc.localhost ; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": ["icons/icon.ico", "icons/icon.png"],
    "publisher": "ntd4996",
    "homepage": "https://github.com/ntd4996/agentpet",
    "shortDescription": "A desktop pet that watches your AI coding agents.",
    "longDescription": "AgentPet floats a pixel companion on your desktop that reacts in real time to your AI coding agents (Claude Code, Codex, Gemini, Cursor, ...).",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": true,
        "languages": ["English", "SimpChinese", "Vietnamese"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNGQjczRkJDRTBENUNEREUKUldUZXpkWGd2RCszUC80OHlGRGQ1THBuUnZ6VnpsQWN5elhvOFNzRDkvY0lNVTlWWHgyR29ML1gK",
      "endpoints": [
        "https://github.com/ntd4996/agentpet/releases/latest/download/latest.json"
      ]
    }
  }
}
